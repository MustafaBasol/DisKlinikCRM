generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id              String       @id @default(uuid())
  name            String
  legalName       String?
  address         String?
  phone           String?
  email           String?
  website         String?
  timezone        String       @default("UTC")
  currency        String       @default("USD")
  defaultLanguage String       @default("en")
  slug            String // Phase 1b: NOT NULL — @@unique([organizationId, slug]) added below
  status          String       @default("trial") // trial | active | suspended | cancelled
  trialEndsAt     DateTime?
  maxUsers        Int          @default(10) // Kept for backwards compat; plan limits read from Organization after migration
  maxPatients     Int          @default(500) // Kept for backwards compat
  planId          String? // Staged migration: kept until Organization.planId is validated
  plan            Plan?        @relation(fields: [planId], references: [id])
  organizationId  String // Phase 1b: NOT NULL after backfill
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  users                         User[]
  doctorAvailabilities          DoctorAvailability[]
  doctorOffDays                 DoctorOffDay[]
  patients                      Patient[]
  appointmentTypes              AppointmentType[]
  appointments                  Appointment[]
  appointmentRequests           AppointmentRequest[]
  contactRequests               ContactRequest[]
  treatmentCases                TreatmentCase[]
  tasks                         Task[]
  payments                      Payment[]
  insuranceProvisions           InsuranceProvision[]
  messageTemplates              MessageTemplate[]
  sentMessages                  SentMessage[]
  activityLogs                  ActivityLog[]
  whatsappConversationStates    WhatsAppConversationState[]
  whatsappConversationMessages  WhatsAppConversationMessage[]
  settings                      Setting[]
  recallSetting                 ClinicRecallSetting?
  recallCandidates              RecallCandidate[]
  recallActions                 RecallAction[]
  patientAttachments            PatientAttachment[]
  toothRecords                  ToothRecord[]
  paymentPlans                  PaymentPlan[]
  practitionerCompRules         PractitionerCompensationRule[]
  serviceCompRules              ServiceCompensationRule[]
  practitionerEarnings          PractitionerEarning[]
  practitionerPayouts           PractitionerPayout[]
  inventoryItems                InventoryItem[]
  inventoryTransactions         InventoryTransaction[]
  treatmentPlanProcedures       TreatmentPlanProcedure[]
  treatmentPackages             TreatmentPackage[]
  treatmentPackageItems         TreatmentPackageItem[]
  appointmentTypeMaterials      AppointmentTypeMaterial[]
  treatmentPackageMaterials     TreatmentPackageMaterial[]
  treatmentPackageApplications  TreatmentPackageApplication[]
  notifications                 Notification[]
  invitations                   ClinicInvitation[]
  defaultUsers                  User[]                         @relation("UserDefaultClinic")
  primaryPatients               Patient[]                      @relation("PatientPrimaryClinic")
  userClinics                   UserClinic[]
  patientClinics                PatientClinic[]
  clinicWorkingHours            ClinicWorkingHours[]
  clinicWhatsAppConnections     ClinicWhatsAppConnection[]
  whatsappInboxEntries          WhatsAppInboxEntry[]           @relation("InboxEntryClinic")
  clinicInstagramConnections    ClinicInstagramConnection[]
  instagramInboxEntries         InstagramInboxEntry[]          @relation("InstagramInboxEntryClinic")
  instagramConversationMessages InstagramConversationMessage[]
  postTreatmentTemplates        PostTreatmentMessageTemplate[]
  postTreatmentQueue            PostTreatmentMessageQueue[]
  patientPrivacyRequests        PatientPrivacyRequest[]
  clinicLegalProfile            ClinicLegalProfile?
  channelConsentLogs            ChannelConsentLog[]
  smsSettings                   ClinicSmsSettings?
  smsMessages                   SmsMessage[]
  smsUsageCounters              SmsUsageCounter[]
  laboratories                  Laboratory[]
  labWorkOrders                 LabWorkOrder[]
  labOrderAttachments           LabOrderAttachment[]
  imagingDevices                ImagingDevice[]
  imagingRequests               ImagingRequest[]
  imagingStudies                ImagingStudy[]
  imagingImages                 ImagingImage[]
  imagingBridgeAgents           ImagingBridgeAgent[]
  imagingBridgePairings         ImagingBridgePairing[]
  imagingBridgeBindings         ImagingBridgeBinding[]
  publicBookingNoticeEvidences  PublicBookingNoticeEvidence[]
  privacyExportArchives         PatientPrivacyExportArchive[]
  clinicBulkExportArchives      ClinicBulkExportArchive[]
  clinicBulkExportPwAttempts    ClinicBulkExportPasswordAttempt[]
  communicationPreferences      PatientCommunicationPreference[]
  communicationConsentEvents    PatientCommunicationConsentEvent[]

  @@unique([organizationId, slug])
}

model User {
  id                  String       @id @default(uuid())
  clinicId            String
  clinic              Clinic       @relation(fields: [clinicId], references: [id])
  firstName           String
  lastName            String
  email               String
  phone               String?
  role                String // OWNER | ORG_ADMIN | CLINIC_MANAGER | DENTIST | RECEPTIONIST | BILLING | ASSISTANT
  passwordHash        String
  /// JWTs issued before this moment are rejected — set on every password change/reset
  passwordChangedAt   DateTime?
  isActive            Boolean      @default(true)
  lastLoginAt         DateTime?
  commissionRate      Float        @default(0)
  emailVerifiedAt     DateTime?
  organizationId      String // Phase 1b: NOT NULL after backfill
  organization        Organization @relation(fields: [organizationId], references: [id])
  defaultClinicId     String? // UI default only — NOT used for authorization
  defaultClinic       Clinic?      @relation("UserDefaultClinic", fields: [defaultClinicId], references: [id])
  canAccessAllClinics Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  tasksCreated                 Task[]                         @relation("TaskCreator")
  tasksAssigned                Task[]                         @relation("TaskAssignee")
  appointments                 Appointment[]                  @relation("Practitioner")
  appointmentRequests          AppointmentRequest[]           @relation("AppointmentRequestPractitioner")
  contactRequestsAssigned      ContactRequest[]               @relation("ContactRequestAssignee")
  contactRequestsResolved      ContactRequest[]               @relation("ContactRequestResolver")
  availabilities               DoctorAvailability[]           @relation("DoctorAvailability")
  offDays                      DoctorOffDay[]                 @relation("DoctorOffDays")
  treatmentCases               TreatmentCase[]                @relation("Practitioner")
  insuranceAssigned            InsuranceProvision[]           @relation("InsuranceAssignedTo")
  insuranceCreated             InsuranceProvision[]           @relation("InsuranceCreatedBy")
  sentMessages                 SentMessage[]
  createdTemplates             MessageTemplate[]              @relation("TemplateCreator")
  activityLogs                 ActivityLog[]
  uploadedAttachments          PatientAttachment[]            @relation("AttachmentUploader")
  privacyExportsRequested      PatientPrivacyExportArchive[]  @relation("PrivacyExportRequester")
  clinicBulkExportsRequested   ClinicBulkExportArchive[]      @relation("ClinicBulkExportRequester")
  clinicBulkExportsStepUpVerified ClinicBulkExportArchive[]   @relation("ClinicBulkExportStepUpVerifier")
  toothRecordsCreated          ToothRecord[]                  @relation("ToothRecordCreator")
  paymentPlans                 PaymentPlan[]
  compensationRules            PractitionerCompensationRule[] @relation("PractitionerCompRules")
  serviceCompRules             ServiceCompensationRule[]      @relation("ServiceCompRules")
  practitionerEarnings         PractitionerEarning[]          @relation("PractitionerEarnings")
  practitionerPayouts          PractitionerPayout[]           @relation("PractitionerPayouts")
  payoutsCreated               PractitionerPayout[]           @relation("PayoutCreator")
  inventoryTransactions        InventoryTransaction[]         @relation("InventoryPerformedBy")
  proceduresCreated            TreatmentPlanProcedure[]       @relation("ProcedureCreator")
  packageApplicationsCreated   TreatmentPackageApplication[]  @relation("TreatmentPackageApplicationCreator")
  userClinics                  UserClinic[]
  resolvedInboxEntries         WhatsAppInboxEntry[]           @relation("InboxEntryResolver")
  resolvedInstagramEntries     InstagramInboxEntry[]          @relation("InstagramInboxEntryResolver")
  assignedRecallCandidates     RecallCandidate[]              @relation("RecallCandidateAssignee")
  performedRecallActions       RecallAction[]                 @relation("RecallActionPerformer")
  passwordResetTokens          PasswordResetToken[]
  emailVerificationTokens      EmailVerificationToken[]
  smsMessagesCreated           SmsMessage[]                   @relation("SmsMessageCreator")
  laboratoriesCreated          Laboratory[]                   @relation("LaboratoryCreator")
  labWorkOrdersCreated         LabWorkOrder[]                 @relation("LabWorkOrderCreator")
  labWorkOrdersAsPractitioner  LabWorkOrder[]                 @relation("LabWorkOrderPractitioner")
  labWorkOrderStatusChanges    LabWorkOrderStatusHistory[]    @relation("LabWorkOrderStatusChanger")
  labOrderAttachmentsUploaded  LabOrderAttachment[]           @relation("LabOrderAttachmentUploader")
  imagingDevicesCreated        ImagingDevice[]                @relation("ImagingDeviceCreator")
  imagingRequestsRequested     ImagingRequest[]               @relation("ImagingRequestRequester")
  imagingStudiesCreated        ImagingStudy[]                 @relation("ImagingStudyCreator")
  imagingBridgeAgentsCreated   ImagingBridgeAgent[]           @relation("ImagingBridgeAgentCreator")
  imagingBridgePairingsCreated ImagingBridgePairing[]         @relation("ImagingBridgePairingCreator")

  // Global uniqueness on lower(email) is enforced by a raw DB index (migration 20260629120000).
}

model DoctorAvailability {
  id             String   @id @default(uuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User     @relation("DoctorAvailability", fields: [practitionerId], references: [id])
  weekday        Int // 0 Sunday, 1 Monday, ... 6 Saturday
  startTime      String // HH:mm
  endTime        String // HH:mm
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clinicId, practitionerId, weekday])
}

model DoctorOffDay {
  id             String   @id @default(uuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User     @relation("DoctorOffDays", fields: [practitionerId], references: [id])
  date           String // YYYY-MM-DD (clinic local date)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clinicId, practitionerId, date])
  @@index([clinicId, practitionerId])
}

model Patient {
  id                   String       @id @default(uuid())
  clinicId             String
  clinic               Clinic       @relation(fields: [clinicId], references: [id])
  firstName            String
  lastName             String
  email                String?
  phone                String?
  dateOfBirth          DateTime?
  address              String?
  city                 String?
  postalCode           String?
  country              String?
  patientStatus        String       @default("new") // new, active, inactive, archived
  source               String? // google, referral, social_media, etc.
  notes                String?
  communicationConsent Boolean      @default(false)
  marketingConsent     Boolean      @default(false)
  // SMS opt-out (KVKK/GDPR): blocks all outbound SMS when set.
  // Foundation for future STOP/RET/IPTAL/UNSUBSCRIBE inbound keywords.
  smsOptOut            Boolean      @default(false)
  smsOptOutAt          DateTime?
  organizationId       String // Phase 1b: NOT NULL after backfill
  organization         Organization @relation(fields: [organizationId], references: [id])
  primaryClinicId      String? // Default/preferred branch (not exclusive)
  primaryClinic        Clinic?      @relation("PatientPrimaryClinic", fields: [primaryClinicId], references: [id])
  // KVKK/GDPR anonymization tracking
  isAnonymized         Boolean      @default(false)
  anonymizedAt         DateTime?
  anonymizedById       String?
  anonymizationReason  String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?

  appointments                  Appointment[]
  appointmentRequests           AppointmentRequest[]
  contactRequests               ContactRequest[]
  treatmentCases                TreatmentCase[]
  tasks                         Task[]
  payments                      Payment[]
  insuranceProvisions           InsuranceProvision[]
  sentMessages                  SentMessage[]
  activityLogs                  ActivityLog[]
  whatsappConversationMessages  WhatsAppConversationMessage[]
  attachments                   PatientAttachment[]
  toothRecords                  ToothRecord[]
  paymentPlans                  PaymentPlan[]
  practitionerEarnings          PractitionerEarning[]
  treatmentPlanProcedures       TreatmentPlanProcedure[]
  treatmentPackageApplications  TreatmentPackageApplication[]
  patientClinics                PatientClinic[]
  whatsappInboxEntries          WhatsAppInboxEntry[]           @relation("InboxEntryPatient")
  instagramInboxEntries         InstagramInboxEntry[]          @relation("InstagramInboxEntryPatient")
  instagramConversationMessages InstagramConversationMessage[]
  postTreatmentQueue            PostTreatmentMessageQueue[]
  recallCandidates              RecallCandidate[]
  recallActions                 RecallAction[]
  privacyRequests               PatientPrivacyRequest[]
  smsMessages                   SmsMessage[]
  labWorkOrders                 LabWorkOrder[]
  imagingRequests               ImagingRequest[]
  imagingStudies                ImagingStudy[]
  communicationPreferences      PatientCommunicationPreference[]
  communicationConsentEvents    PatientCommunicationConsentEvent[]

  @@index([clinicId, phone])
  @@index([clinicId, email])
}

model AppointmentType {
  id              String   @id @default(uuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  name            String
  durationMinutes Int
  color           String?
  isActive        Boolean  @default(true)
  category        String?
  description     String?
  basePrice       Float?
  currency        String?
  isService       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments            Appointment[]
  appointmentRequests     AppointmentRequest[]
  treatmentCases          TreatmentCase[]
  serviceCompRules        ServiceCompensationRule[]      @relation("ServiceCompRules")
  practitionerEarnings    PractitionerEarning[]          @relation("EarningService")
  treatmentPlanProcedures TreatmentPlanProcedure[]
  packageItems            TreatmentPackageItem[]
  materials               AppointmentTypeMaterial[]
  inventoryTransactions   InventoryTransaction[]         @relation("InventoryTransactionService")
  postTreatmentTemplates  PostTreatmentMessageTemplate[]
  postTreatmentQueue      PostTreatmentMessageQueue[]
}

model Appointment {
  id                 String          @id @default(uuid())
  clinicId           String
  clinic             Clinic          @relation(fields: [clinicId], references: [id])
  patientId          String
  patient            Patient         @relation(fields: [patientId], references: [id])
  practitionerId     String
  practitioner       User            @relation("Practitioner", fields: [practitionerId], references: [id])
  appointmentTypeId  String
  appointmentType    AppointmentType @relation(fields: [appointmentTypeId], references: [id])
  title              String?
  startTime          DateTime
  endTime            DateTime
  status             String          @default("scheduled") // scheduled, confirmed, completed, cancelled, no_show, etc.
  notes              String?
  cancellationReason String?
  noShowReason       String?
  // No-show recovery fields (Sprint 18)
  noShowMarkedAt     DateTime?
  noShowMarkedById   String?
  recoveryStatus     String? // unresolved | contacted | recovered
  recoveryNote       String?
  recoveredAt        DateTime?
  recoveredById      String?
  createdById        String?
  updatedById        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])

  tasks            Task[]
  sentMessages     SentMessage[]
  activityLogs     ActivityLog[]
  recallCandidates RecallCandidate[]
  recallActions    RecallAction[]
  sourceRequests   AppointmentRequest[] @relation("ConvertedAppointment")
  smsMessages      SmsMessage[]
  imagingRequests  ImagingRequest[]
  imagingStudies   ImagingStudy[]

  // Postgres'te Prisma FK kolonlarına otomatik indeks koymaz; takvim ve
  // uygunluk (available-slots) sorguları bu indeksler olmadan tablo taraması yapar.
  @@index([clinicId, startTime])
  @@index([practitionerId, startTime])
  @@index([patientId])
}

model AppointmentRequest {
  id                     String           @id @default(uuid())
  clinicId               String
  clinic                 Clinic           @relation(fields: [clinicId], references: [id])
  patientId              String?
  patient                Patient?         @relation(fields: [patientId], references: [id])
  patientName            String
  phone                  String
  email                  String?
  appointmentTypeId      String?
  appointmentType        AppointmentType? @relation(fields: [appointmentTypeId], references: [id])
  practitionerId         String?
  practitioner           User?            @relation("AppointmentRequestPractitioner", fields: [practitionerId], references: [id])
  preferredStartTime     DateTime?
  preferredEndTime       DateTime?
  requestType            String           @default("appointment") // appointment, reschedule, cancel, info
  source                 String           @default("whatsapp")
  externalSenderId       String?
  sourceConnectionId     String?
  sourceInboxEntryId     String?
  sourceConversationId   String?
  status                 String           @default("pending") // pending, approved, rejected, converted, closed
  rawMessage             String?
  notes                  String?
  rejectionReason        String?
  convertedAppointmentId String?
  convertedAppointment   Appointment?     @relation("ConvertedAppointment", fields: [convertedAppointmentId], references: [id])
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  noticeEvidence PublicBookingNoticeEvidence?

  @@index([clinicId, status, createdAt])
  @@index([clinicId, phone])
  @@index([clinicId, practitionerId])
  @@index([source, status, createdAt])
  @@index([sourceInboxEntryId])
}

model ContactRequest {
  id                   String    @id @default(uuid())
  clinicId             String
  clinic               Clinic    @relation(fields: [clinicId], references: [id])
  patientId            String?
  patient              Patient?  @relation(fields: [patientId], references: [id])
  channel              String // whatsapp, meta_whatsapp, instagram, manual
  sourceConversationId String?
  sourceMessageId      String?
  externalSenderId     String?
  phone                String?
  name                 String?
  type                 String    @default("staff_handoff") // callback_request, staff_handoff, information_request, complaint, other
  status               String    @default("pending") // pending, in_progress, resolved, closed
  priority             String    @default("normal") // normal, urgent
  note                 String?
  lastMessage          String?
  assignedToId         String?
  assignedTo           User?     @relation("ContactRequestAssignee", fields: [assignedToId], references: [id])
  resolvedById         String?
  resolvedBy           User?     @relation("ContactRequestResolver", fields: [resolvedById], references: [id])
  resolvedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([clinicId, status])
  @@index([clinicId, channel])
  @@index([clinicId, externalSenderId])
  @@index([clinicId, createdAt])
}

model WhatsAppConversationState {
  id                          String   @id @default(uuid())
  clinicId                    String
  clinic                      Clinic   @relation(fields: [clinicId], references: [id])
  phone                       String
  lastProviderMessageId       String?
  customerName                String?
  currentIntent               String?
  step                        String?
  selectedAppointmentTypeId   String?
  selectedAppointmentTypeName String?
  selectedPractitionerId      String?
  selectedDate                String?
  selectedTime                String?
  lastMessage                 String?
  stateJson                   Json?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([clinicId, phone])
  @@index([clinicId, updatedAt])
}

model WhatsAppConversationMessage {
  id                String   @id @default(uuid())
  clinicId          String
  clinic            Clinic   @relation(fields: [clinicId], references: [id])
  patientId         String?
  patient           Patient? @relation(fields: [patientId], references: [id])
  phone             String
  providerMessageId String?
  direction         String
  text              String
  rawPayload        Json?
  createdAt         DateTime @default(now())

  @@unique([clinicId, providerMessageId])
  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, phone, createdAt])
}

model TreatmentCase {
  id                String           @id @default(uuid())
  clinicId          String
  clinic            Clinic           @relation(fields: [clinicId], references: [id])
  patientId         String
  patient           Patient          @relation(fields: [patientId], references: [id])
  practitionerId    String?
  practitioner      User?            @relation("Practitioner", fields: [practitionerId], references: [id])
  appointmentTypeId String?
  appointmentType   AppointmentType? @relation(fields: [appointmentTypeId], references: [id])
  title             String
  description       String?
  stage             String           @default("new") // new, quote_sent, in_progress, completed, lost
  estimatedAmount   Float?
  acceptedAmount    Float?
  currency          String?
  expectedStartDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  createdById       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  tasks                 Task[]
  appointments          Appointment[]
  payments              Payment[]
  insuranceProvisions   InsuranceProvision[]
  sentMessages          SentMessage[]
  activityLogs          ActivityLog[]
  paymentPlans          PaymentPlan[]
  practitionerEarnings  PractitionerEarning[]
  inventoryTransactions InventoryTransaction[]
  procedures            TreatmentPlanProcedure[]
  packageApplications   TreatmentPackageApplication[]
  recallCandidates      RecallCandidate[]
  labWorkOrders         LabWorkOrder[]
  imagingRequests       ImagingRequest[]
  imagingStudies        ImagingStudy[]
}

model TreatmentPackage {
  id              String   @id @default(uuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  name            String
  description     String?
  category        String?
  color           String?
  durationMinutes Int?
  price           Float?
  currency        String   @default("TRY")
  pricingMode     String   @default("PACKAGE_PRICE") // PACKAGE_PRICE | SERVICE_SUM
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items                  TreatmentPackageItem[]
  materials              TreatmentPackageMaterial[]
  applications           TreatmentPackageApplication[]
  procedures             TreatmentPlanProcedure[]
  inventoryTransactions  InventoryTransaction[]
  postTreatmentTemplates PostTreatmentMessageTemplate[]
  postTreatmentQueue     PostTreatmentMessageQueue[]

  @@unique([clinicId, name])
  @@index([clinicId, isActive])
}

model TreatmentPackageItem {
  id                  String           @id @default(uuid())
  clinicId            String
  clinic              Clinic           @relation(fields: [clinicId], references: [id])
  packageId           String
  treatmentPackage    TreatmentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  serviceId           String
  service             AppointmentType  @relation(fields: [serviceId], references: [id])
  quantity            Int              @default(1)
  sortOrder           Int              @default(0)
  overridePrice       Float?
  overrideDurationMin Int?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  procedures TreatmentPlanProcedure[]

  @@unique([packageId, serviceId])
  @@index([clinicId])
  @@index([packageId])
  @@index([serviceId])
}

model AppointmentTypeMaterial {
  id              String          @id @default(uuid())
  clinicId        String
  clinic          Clinic          @relation(fields: [clinicId], references: [id])
  serviceId       String
  service         AppointmentType @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id])
  quantity        Float
  unit            String?
  deductionTiming String          @default("ON_TREATMENT_COMPLETED")
  isOptional      Boolean         @default(false)
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([serviceId, inventoryItemId])
  @@index([clinicId])
  @@index([serviceId])
  @@index([inventoryItemId])
}

model TreatmentPackageMaterial {
  id               String           @id @default(uuid())
  clinicId         String
  clinic           Clinic           @relation(fields: [clinicId], references: [id])
  packageId        String
  treatmentPackage TreatmentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  inventoryItemId  String
  inventoryItem    InventoryItem    @relation(fields: [inventoryItemId], references: [id])
  quantity         Float
  unit             String?
  deductionTiming  String           @default("ON_TREATMENT_COMPLETED")
  isOptional       Boolean          @default(false)
  note             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([packageId, inventoryItemId])
  @@index([clinicId])
  @@index([packageId])
  @@index([inventoryItemId])
}

model TreatmentPackageApplication {
  id                            String           @id @default(uuid())
  clinicId                      String
  clinic                        Clinic           @relation(fields: [clinicId], references: [id])
  treatmentCaseId               String
  treatmentCase                 TreatmentCase    @relation(fields: [treatmentCaseId], references: [id])
  patientId                     String
  patient                       Patient          @relation(fields: [patientId], references: [id])
  packageId                     String
  treatmentPackage              TreatmentPackage @relation(fields: [packageId], references: [id])
  pricingMode                   String
  totalDurationMinutes          Int?
  totalPrice                    Float?
  currency                      String?
  createdById                   String
  createdBy                     User             @relation("TreatmentPackageApplicationCreator", fields: [createdById], references: [id])
  extraMaterialsDeductedAt      DateTime?
  extraMaterialsDeductionStatus String?
  extraMaterialsDeductionError  String?
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt

  procedures            TreatmentPlanProcedure[]
  inventoryTransactions InventoryTransaction[]

  @@index([clinicId, treatmentCaseId])
  @@index([clinicId, packageId])
  @@index([clinicId, patientId])
}

model InsuranceProvision {
  id                          String         @id @default(uuid())
  clinicId                    String
  clinic                      Clinic         @relation(fields: [clinicId], references: [id])
  patientId                   String
  patient                     Patient        @relation(fields: [patientId], references: [id])
  treatmentCaseId             String?
  treatmentCase               TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  insuranceProviderName       String
  insuranceType               String
  policyNumber                String?
  provisionNumber             String?
  status                      String         @default("draft")
  requestedAmount             Float
  approvedAmount              Float?
  patientResponsibilityAmount Float?
  currency                    String         @default("TRY")
  submittedAt                 DateTime?
  respondedAt                 DateTime?
  rejectionReason             String?
  notes                       String?
  assignedToId                String?
  assignedTo                  User?          @relation("InsuranceAssignedTo", fields: [assignedToId], references: [id])
  createdById                 String
  createdBy                   User           @relation("InsuranceCreatedBy", fields: [createdById], references: [id])
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  activityLogs ActivityLog[]
}

model Task {
  id              String         @id @default(uuid())
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  patientId       String?
  patient         Patient?       @relation(fields: [patientId], references: [id])
  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  appointmentId   String?
  appointment     Appointment?   @relation(fields: [appointmentId], references: [id])
  assignedToId    String?
  assignedTo      User?          @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User           @relation("TaskCreator", fields: [createdById], references: [id])
  title           String
  description     String?
  dueDate         DateTime?
  status          String         @default("open") // open, in_progress, completed, cancelled
  priority        String         @default("normal") // low, normal, high, urgent
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  recallActions RecallAction[]

  @@index([clinicId, status])
}

model Payment {
  id              String         @id @default(uuid())
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  amount          Float
  currency        String
  paymentMethod   String // cash, card, bank_transfer, etc.
  paymentStatus   String         @default("pending") // pending, partial, paid, refunded, cancelled
  paidAt          DateTime?
  notes           String?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sentMessages         SentMessage[]
  installment          PaymentPlanInstallment?
  practitionerEarnings PractitionerEarning[]
  recallCandidates     RecallCandidate[]

  @@index([clinicId, createdAt])
  @@index([patientId])
}

model MessageTemplate {
  id        String   @id @default(uuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  name      String
  channel   String // sms, whatsapp, email
  subject   String?
  body      String
  language  String   @default("en")
  isActive  Boolean  @default(true)
  purpose   String   @default("general_message") // appointment_reminder | payment_reminder | appointment_confirmation | no_show_recovery | post_treatment_followup | general_message
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation("TemplateCreator", fields: [createdById], references: [id])

  // Meta WhatsApp Template Management
  metaTemplateName            String?
  metaTemplateLanguage        String?
  metaTemplateCategory        String? // utility, marketing, authentication
  metaTemplateStatus          String? // draft, submitted, approved, rejected, paused, disabled, unknown
  metaTemplateId              String?
  metaTemplateRejectionReason String?
  metaTemplateLastSyncedAt    DateTime?
  metaTemplateSubmittedAt     DateTime?
  metaTemplateVariableMap     Json?

  // Snapshot of the WhatsApp connection/WABA this template was submitted against.
  // Lets us detect when a clinic's active connection later changes to a different
  // WABA, so a previously-approved template isn't silently trusted for the new one.
  metaTemplateConnectionId  String?
  metaTemplateConnection    WhatsAppConnection? @relation("MessageTemplateMetaConnection", fields: [metaTemplateConnectionId], references: [id])
  metaWabaIdSnapshot        String?
  metaPhoneNumberIdSnapshot String?

  sentMessages     SentMessage[]
  recallCandidates RecallCandidate[]
  smsMessages      SmsMessage[]      @relation("SmsMessageTemplate")

  @@index([metaTemplateConnectionId])
}

model SentMessage {
  id                   String              @id @default(uuid())
  clinicId             String
  clinic               Clinic              @relation(fields: [clinicId], references: [id])
  patientId            String
  patient              Patient             @relation(fields: [patientId], references: [id])
  appointmentId        String?
  appointment          Appointment?        @relation(fields: [appointmentId], references: [id])
  treatmentCaseId      String?
  treatmentCase        TreatmentCase?      @relation(fields: [treatmentCaseId], references: [id])
  paymentId            String?
  payment              Payment?            @relation(fields: [paymentId], references: [id])
  templateId           String?
  template             MessageTemplate?    @relation(fields: [templateId], references: [id])
  channel              String
  recipient            String
  subject              String?
  body                 String
  status               String              @default("prepared") // prepared, sent, failed, delivered, read
  providerMessageId    String?
  sentAt               DateTime?
  createdById          String?
  createdBy            User?               @relation(fields: [createdById], references: [id])
  // Provider-agnostic WhatsApp extension fields
  organizationId       String?
  organization         Organization?       @relation(fields: [organizationId], references: [id])
  whatsappConnectionId String?
  whatsappConnection   WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id])
  provider             String? // evolution_api | meta_cloud_api
  direction            String? // outgoing | incoming
  externalMessageId    String? // Provider message ID for tracking
  createdAt            DateTime            @default(now())

  recallActions RecallAction[]

  // Reminder job'ın randevu başına dedup kontrolü (clinicId+appointmentId) ve
  // taksit hatırlatması dedup anahtarı (clinicId+subject) bu indeksleri kullanır.
  @@index([clinicId, appointmentId, createdAt])
  @@index([clinicId, subject])
  @@index([patientId])
}

model ActivityLog {
  id                   String   @id @default(uuid())
  clinicId             String
  clinic               Clinic   @relation(fields: [clinicId], references: [id])
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  entityType           String
  entityId             String // Legacy or general fallback
  patientId            String?
  appointmentId        String?
  treatmentCaseId      String?
  insuranceProvisionId String?
  action               String
  description          String?
  metadataJson         String?
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime @default(now())

  patient            Patient?            @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointment        Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  treatmentCase      TreatmentCase?      @relation(fields: [treatmentCaseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  insuranceProvision InsuranceProvision? @relation(fields: [insuranceProvisionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([clinicId, createdAt])
  @@index([patientId])
}

model Setting {
  id        String   @id @default(uuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, key])
}

model ClinicRecallSetting {
  id                                     String   @id @default(uuid())
  clinicId                               String   @unique
  clinic                                 Clinic   @relation(fields: [clinicId], references: [id])
  isEnabled                              Boolean  @default(false)
  defaultActionMode                      String   @default("LIST_ONLY") // LIST_ONLY | CREATE_TASK | CREATE_MESSAGE_DRAFT | AUTO_SEND_WHATSAPP
  checkupEnabled                         Boolean  @default(true)
  checkupAfterDays                       Int      @default(180)
  checkupSendTiming                      String   @default("MANUAL") // SAME_DAY | NEXT_DAY | MANUAL
  checkupSendTime                        String   @default("10:00")
  checkupActionMode                      String   @default("LIST_ONLY")
  checkupMessageTemplateId               String?
  treatmentPlanFollowupEnabled           Boolean  @default(true)
  treatmentPlanFollowupAfterDays         Int      @default(7)
  treatmentPlanFollowupRepeatDays        Int      @default(14)
  treatmentPlanFollowupMaxAttempts       Int      @default(3)
  treatmentPlanFollowupActionMode        String   @default("CREATE_TASK")
  treatmentPlanFollowupMessageTemplateId String?
  incompleteTreatmentEnabled             Boolean  @default(true)
  incompleteTreatmentAfterDays           Int      @default(14)
  incompleteTreatmentActionMode          String   @default("CREATE_TASK")
  incompleteTreatmentMessageTemplateId   String?
  incompleteTreatmentAutoCreateTask      Boolean  @default(true)
  noShowFollowupEnabled                  Boolean  @default(true)
  noShowFollowupAfterHours               Int      @default(24)
  noShowFollowupActionMode               String   @default("CREATE_TASK")
  noShowFollowupMessageTemplateId        String?
  noShowFollowupAutoCreateTask           Boolean  @default(true)
  paymentFollowupEnabled                 Boolean  @default(true)
  paymentFollowupAfterDays               Int      @default(3)
  paymentFollowupActionMode              String   @default("CREATE_TASK")
  paymentFollowupMessageTemplateId       String?
  respectCommunicationConsent            Boolean  @default(true)
  createdAt                              DateTime @default(now())
  updatedAt                              DateTime @updatedAt

  @@index([clinicId])
}

model RecallCandidate {
  id                       String                  @id @default(uuid())
  clinicId                 String
  clinic                   Clinic                  @relation(fields: [clinicId], references: [id])
  patientId                String
  patient                  Patient                 @relation(fields: [patientId], references: [id])
  recallType               String
  priority                 String                  @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  status                   String                  @default("PENDING") // PENDING | TASK_CREATED | MESSAGE_DRAFTED | CONTACTED | APPOINTMENT_BOOKED | DECLINED | SNOOZED | COMPLETED | CANCELLED
  sourceType               String
  sourceId                 String
  treatmentCaseId          String?
  treatmentCase            TreatmentCase?          @relation(fields: [treatmentCaseId], references: [id])
  treatmentPlanProcedureId String?
  treatmentPlanProcedure   TreatmentPlanProcedure? @relation(fields: [treatmentPlanProcedureId], references: [id])
  appointmentId            String?
  appointment              Appointment?            @relation(fields: [appointmentId], references: [id])
  paymentId                String?
  payment                  Payment?                @relation(fields: [paymentId], references: [id])
  estimatedValue           Float?
  dueAt                    DateTime
  lastContactedAt          DateTime?
  nextActionAt             DateTime?
  attemptsCount            Int                     @default(0)
  maxAttempts              Int                     @default(3)
  assignedToId             String?
  assignedTo               User?                   @relation("RecallCandidateAssignee", fields: [assignedToId], references: [id])
  messageTemplateId        String?
  messageTemplate          MessageTemplate?        @relation(fields: [messageTemplateId], references: [id])
  lastMessageDraft         String?
  note                     String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  completedAt              DateTime?
  cancelledAt              DateTime?

  actions RecallAction[]

  @@index([clinicId, status, dueAt])
  @@index([clinicId, recallType, status])
  @@index([clinicId, patientId])
  @@index([clinicId, sourceType, sourceId])
  @@index([assignedToId])
}

model RecallAction {
  id            String          @id @default(uuid())
  clinicId      String
  clinic        Clinic          @relation(fields: [clinicId], references: [id])
  candidateId   String
  candidate     RecallCandidate @relation(fields: [candidateId], references: [id])
  patientId     String
  patient       Patient         @relation(fields: [patientId], references: [id])
  actionType    String
  status        String          @default("completed")
  performedById String?
  performedBy   User?           @relation("RecallActionPerformer", fields: [performedById], references: [id])
  taskId        String?
  task          Task?           @relation(fields: [taskId], references: [id])
  messageId     String?
  message       SentMessage?    @relation(fields: [messageId], references: [id])
  appointmentId String?
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id])
  note          String?
  createdAt     DateTime        @default(now())

  @@index([clinicId, candidateId])
  @@index([clinicId, patientId])
  @@index([clinicId, actionType, createdAt])
}

model PatientAttachment {
  id           String   @id @default(uuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  fileName     String
  originalName String
  fileSize     Int
  mimeType     String
  filePath     String
  uploadedById String
  uploadedBy   User     @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  /// KVKK lifecycle (docs/compliance/53): when true, blocks anonymization
  /// metadata redaction AND the deletion-review/execute live-delete path for
  /// this attachment. Set only via the legal-hold PATCH endpoint
  /// (OWNER/ORG_ADMIN) — no automatic trigger is implemented in this PR.
  legalHold       Boolean   @default(false)
  legalHoldReason String?
  /// Set by the orphan-check inspection (docs/compliance/53) when the DB row
  /// exists but the physical file could not be found in storage. Informational
  /// only — never used to trigger any automatic deletion.
  storageVerifiedMissingAt DateTime?

  @@index([clinicId, legalHold])
}

model ToothRecord {
  id          String   @id @default(uuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  toothFdi    Int // FDI notation: 11-18, 21-28, 31-38, 41-48
  status      String // planned, treated, issue, missing, crown, implant
  note        String?
  createdById String
  createdBy   User     @relation("ToothRecordCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([patientId, toothFdi])
  @@index([clinicId, patientId])
}

model PaymentPlan {
  id               String         @id @default(uuid())
  clinicId         String
  clinic           Clinic         @relation(fields: [clinicId], references: [id])
  patientId        String
  patient          Patient        @relation(fields: [patientId], references: [id])
  treatmentCaseId  String?
  treatmentCase    TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  totalAmount      Float
  currency         String         @default("TRY")
  installmentCount Int
  description      String?
  status           String         @default("active") // active, completed, cancelled
  createdById      String?
  createdBy        User?          @relation(fields: [createdById], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  installments PaymentPlanInstallment[]

  @@index([clinicId, patientId])
  @@index([clinicId, status])
}

model PaymentPlanInstallment {
  id            String      @id @default(uuid())
  planId        String
  plan          PaymentPlan @relation(fields: [planId], references: [id])
  installmentNo Int
  dueDate       DateTime
  amount        Float
  status        String      @default("pending") // pending, paid, overdue
  paymentId     String?     @unique
  payment       Payment?    @relation(fields: [paymentId], references: [id])
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([planId])
  @@index([dueDate, status])
}

// ─── Practitioner Earnings ──────────────────────────────────────────────────

model PractitionerCompensationRule {
  id                 String    @id @default(uuid())
  clinicId           String
  clinic             Clinic    @relation(fields: [clinicId], references: [id])
  practitionerId     String
  practitioner       User      @relation("PractitionerCompRules", fields: [practitionerId], references: [id])
  compensationType   String    @default("percentage") // fixed | percentage | fixed_plus_percentage | per_service
  fixedMonthlyAmount Float?
  defaultPercentage  Float?
  calculationBase    String    @default("collected") // billed | collected
  startDate          DateTime?
  endDate            DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([clinicId, practitionerId, isActive])
}

model ServiceCompensationRule {
  id             String          @id @default(uuid())
  clinicId       String
  clinic         Clinic          @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User            @relation("ServiceCompRules", fields: [practitionerId], references: [id])
  serviceId      String
  service        AppointmentType @relation("ServiceCompRules", fields: [serviceId], references: [id])
  percentage     Float?
  fixedAmount    Float?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([practitionerId, serviceId])
  @@index([clinicId, practitionerId, isActive])
}

model PractitionerEarning {
  id                    String              @id @default(uuid())
  clinicId              String
  clinic                Clinic              @relation(fields: [clinicId], references: [id])
  practitionerId        String
  practitioner          User                @relation("PractitionerEarnings", fields: [practitionerId], references: [id])
  patientId             String?
  patient               Patient?            @relation(fields: [patientId], references: [id])
  treatmentCaseId       String?
  treatmentCase         TreatmentCase?      @relation(fields: [treatmentCaseId], references: [id])
  paymentId             String?
  payment               Payment?            @relation(fields: [paymentId], references: [id])
  serviceId             String?
  service               AppointmentType?    @relation("EarningService", fields: [serviceId], references: [id])
  grossAmount           Float
  collectedAmount       Float               @default(0)
  earningAmount         Float
  calculationBase       String // billed | collected
  percentageApplied     Float?
  fixedAmountApplied    Float?
  status                String              @default("pending") // pending | approved | paid | cancelled
  periodMonth           Int
  periodYear            Int
  adminAdjustmentAmount Float?
  adminAdjustmentReason String?
  approvedAt            DateTime?
  approvedById          String?
  payoutId              String?
  payout                PractitionerPayout? @relation(fields: [payoutId], references: [id])
  paidAt                DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([clinicId, practitionerId, periodYear, periodMonth])
  @@index([clinicId, status])
}

model PractitionerPayout {
  id             String   @id @default(uuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User     @relation("PractitionerPayouts", fields: [practitionerId], references: [id])
  amount         Float
  paymentDate    DateTime
  periodMonth    Int
  periodYear     Int
  method         String   @default("bank_transfer") // cash | bank_transfer | card | other
  note           String?
  createdById    String
  createdBy      User     @relation("PayoutCreator", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  earnings PractitionerEarning[]

  @@index([clinicId, practitionerId, periodYear, periodMonth])
}

// ── Stok / Malzeme Takibi ────────────────────────────────────────────────────

model InventoryItem {
  id             String       @id @default(uuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id])
  name           String
  // implant | prosthetic | consumable | medication | equipment | other
  category       String       @default("consumable")
  unit           String       @default("piece") // piece | box | ml | gram | vial | set
  currentStock   Float        @default(0)
  minimumStock   Float        @default(0) // triggers low-stock alert
  unitCost       Float?
  supplier       String?
  barcode        String?
  notes          String?
  isActive       Boolean      @default(true)
  organizationId String // Phase 1b: NOT NULL after backfill
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  transactions              InventoryTransaction[]
  appointmentTypeMaterials  AppointmentTypeMaterial[]
  treatmentPackageMaterials TreatmentPackageMaterial[]

  @@index([clinicId, category, isActive])
}

model InventoryTransaction {
  id                       String                       @id @default(uuid())
  clinicId                 String
  clinic                   Clinic                       @relation(fields: [clinicId], references: [id])
  itemId                   String
  item                     InventoryItem                @relation(fields: [itemId], references: [id])
  // in | out | adjustment
  type                     String
  quantity                 Float
  unitCost                 Float?
  // purchase | usage | treatment_use | adjustment | wastage | return
  reason                   String?
  treatmentCaseId          String?
  treatmentCase            TreatmentCase?               @relation(fields: [treatmentCaseId], references: [id])
  treatmentPlanProcedureId String?
  treatmentPlanProcedure   TreatmentPlanProcedure?      @relation(fields: [treatmentPlanProcedureId], references: [id])
  serviceId                String?
  service                  AppointmentType?             @relation("InventoryTransactionService", fields: [serviceId], references: [id])
  treatmentPackageId       String?
  treatmentPackage         TreatmentPackage?            @relation(fields: [treatmentPackageId], references: [id])
  packageApplicationId     String?
  packageApplication       TreatmentPackageApplication? @relation(fields: [packageApplicationId], references: [id])
  performedById            String
  performedBy              User                         @relation("InventoryPerformedBy", fields: [performedById], references: [id])
  notes                    String?
  createdAt                DateTime                     @default(now())

  @@index([clinicId, itemId, createdAt])
  @@index([clinicId, treatmentPlanProcedureId])
  @@index([clinicId, packageApplicationId])
}

// ── Tedavi Planı Görselleştirme ───────────────────────────────────────────────

model TreatmentPlanProcedure {
  id                   String                       @id @default(uuid())
  clinicId             String
  clinic               Clinic                       @relation(fields: [clinicId], references: [id])
  treatmentCaseId      String
  treatmentCase        TreatmentCase                @relation(fields: [treatmentCaseId], references: [id])
  patientId            String
  patient              Patient                      @relation(fields: [patientId], references: [id])
  toothFdi             Int? // FDI notation; null = procedure not tooth-specific
  procedureName        String
  serviceId            String?
  service              AppointmentType?             @relation(fields: [serviceId], references: [id])
  packageApplicationId String?
  packageApplication   TreatmentPackageApplication? @relation(fields: [packageApplicationId], references: [id])
  treatmentPackageId   String?
  treatmentPackage     TreatmentPackage?            @relation(fields: [treatmentPackageId], references: [id])
  packageItemId        String?
  packageItem          TreatmentPackageItem?        @relation(fields: [packageItemId], references: [id])
  // planned | in_progress | completed | cancelled
  status               String                       @default("planned")
  notes                String?
  estimatedCost        Float?
  scheduledDate        DateTime?
  completedAt          DateTime?
  stockDeductedAt      DateTime?
  stockDeductionStatus String?
  stockDeductionError  String?
  createdById          String
  createdBy            User                         @relation("ProcedureCreator", fields: [createdById], references: [id])
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  inventoryTransactions InventoryTransaction[]
  recallCandidates      RecallCandidate[]

  @@index([clinicId, treatmentCaseId])
  @@index([clinicId, patientId, toothFdi])
  @@index([clinicId, packageApplicationId])
  @@index([clinicId, treatmentPackageId])
}

// ── Kalıcı Bildirimler ────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id])
  // upcoming_appointment | overdue_task | appointment_request | low_stock
  type       String
  title      String
  subtitle   String?
  link       String
  isRead     Boolean  @default(false)
  // deterministic key to prevent duplicate inserts (e.g. "appt-{id}", "lowstock-{itemId}")
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([clinicId, externalId])
  @@index([clinicId, isRead])
}

// ── Multi-Tenant Platform Models ─────────────────────────────────────────────

model Plan {
  id           String   @id @default(uuid())
  name         String   @unique // starter | professional | enterprise
  displayName  String
  maxUsers     Int
  maxPatients  Int
  features     Json // { "whatsapp": true, "reports": true, "compensation": false }
  monthlyPrice Decimal  @default(0) @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  clinics       Clinic[]
  organizations Organization[]
}

model PlatformAdmin {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  name                String
  isActive            Boolean   @default(true)
  /// AES-256-GCM şifreli TOTP secret'ı (`enc:v1:` önekli, utils/encryption.ts)
  totpSecretEncrypted String?
  /// Dolu ise login'de TOTP kodu zorunludur; setup → verify akışıyla set edilir
  totpEnabledAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // KVKK-CRIT-003 — security incident lifecycle back-relations. All
  // onDelete: SetNull on the owning side so a deleted/deactivated Platform
  // Admin never destroys incident history.
  securityIncidentsAssigned     SecurityIncident[]         @relation("SecurityIncidentAssignee")
  securityIncidentsAcknowledged SecurityIncident[]         @relation("SecurityIncidentAcknowledger")
  securityIncidentsContained    SecurityIncident[]         @relation("SecurityIncidentContainer")
  securityIncidentsResolved     SecurityIncident[]         @relation("SecurityIncidentResolver")
  securityIncidentsClosed       SecurityIncident[]         @relation("SecurityIncidentCloser")
  securityIncidentActivity      SecurityIncidentActivity[] @relation("SecurityIncidentActivityActor")
}

model ClinicInvitation {
  id             String        @id @default(uuid())
  clinicId       String
  clinic         Clinic        @relation(fields: [clinicId], references: [id])
  email          String
  role           String
  token          String        @unique
  expiresAt      DateTime
  usedAt         DateTime?
  organizationId String? // Nullable: set when invitation is org-scoped
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())

  @@index([clinicId, email])
  @@index([token])
}

// ── Multi-Branch Organization Models ─────────────────────────────────────────────────

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  status      String    @default("trial") // trial | active | suspended | cancelled
  planId      String?
