generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id              String       @id @default(uuid())
  name            String
  legalName       String?
  address         String?
  phone           String?
  email           String?
  website         String?
  timezone        String       @default("UTC")
  currency        String       @default("USD")
  defaultLanguage String       @default("en")
  slug            String // Phase 1b: NOT NULL — @@unique([organizationId, slug]) added below
  status          String       @default("trial") // trial | active | suspended | cancelled
  trialEndsAt     DateTime?
  maxUsers        Int          @default(10) // Kept for backwards compat; plan limits read from Organization after migration
  maxPatients     Int          @default(500) // Kept for backwards compat
  planId          String? // Staged migration: kept until Organization.planId is validated
  plan            Plan?        @relation(fields: [planId], references: [id])
  organizationId  String // Phase 1b: NOT NULL after backfill
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  users                        User[]
  doctorAvailabilities         DoctorAvailability[]
  doctorOffDays                DoctorOffDay[]
  patients                     Patient[]
  appointmentTypes             AppointmentType[]
  appointments                 Appointment[]
  appointmentRequests          AppointmentRequest[]
  contactRequests              ContactRequest[]
  treatmentCases               TreatmentCase[]
  tasks                        Task[]
  payments                     Payment[]
  insuranceProvisions          InsuranceProvision[]
  messageTemplates             MessageTemplate[]
  sentMessages                 SentMessage[]
  activityLogs                 ActivityLog[]
  whatsappConversationStates   WhatsAppConversationState[]
  whatsappConversationMessages WhatsAppConversationMessage[]
  settings                     Setting[]
  recallSetting                ClinicRecallSetting?
  recallCandidates             RecallCandidate[]
  recallActions                RecallAction[]
  patientAttachments           PatientAttachment[]
  toothRecords                 ToothRecord[]
  paymentPlans                 PaymentPlan[]
  practitionerCompRules        PractitionerCompensationRule[]
  serviceCompRules             ServiceCompensationRule[]
  practitionerEarnings         PractitionerEarning[]
  practitionerPayouts          PractitionerPayout[]
  inventoryItems               InventoryItem[]
  inventoryTransactions        InventoryTransaction[]
  treatmentPlanProcedures      TreatmentPlanProcedure[]
  treatmentPackages            TreatmentPackage[]
  treatmentPackageItems        TreatmentPackageItem[]
  appointmentTypeMaterials     AppointmentTypeMaterial[]
  treatmentPackageMaterials    TreatmentPackageMaterial[]
  treatmentPackageApplications TreatmentPackageApplication[]
  notifications                Notification[]
  invitations                  ClinicInvitation[]
  defaultUsers                 User[]                         @relation("UserDefaultClinic")
  primaryPatients              Patient[]                      @relation("PatientPrimaryClinic")
  userClinics                  UserClinic[]
  patientClinics               PatientClinic[]
  clinicWorkingHours           ClinicWorkingHours[]
  clinicWhatsAppConnections    ClinicWhatsAppConnection[]
  whatsappInboxEntries         WhatsAppInboxEntry[]           @relation("InboxEntryClinic")
  clinicInstagramConnections        ClinicInstagramConnection[]
  instagramInboxEntries             InstagramInboxEntry[]          @relation("InstagramInboxEntryClinic")
  instagramConversationMessages     InstagramConversationMessage[]
  postTreatmentTemplates            PostTreatmentMessageTemplate[]
  postTreatmentQueue                PostTreatmentMessageQueue[]
  patientPrivacyRequests            PatientPrivacyRequest[]
  clinicLegalProfile                ClinicLegalProfile?

  @@unique([organizationId, slug])
}

model User {
  id                  String       @id @default(uuid())
  clinicId            String
  clinic              Clinic       @relation(fields: [clinicId], references: [id])
  firstName           String
  lastName            String
  email               String
  phone               String?
  role                String // OWNER | ORG_ADMIN | CLINIC_MANAGER | DENTIST | RECEPTIONIST | BILLING | ASSISTANT
  passwordHash        String
  isActive            Boolean      @default(true)
  lastLoginAt         DateTime?
  commissionRate      Float        @default(0)
  emailVerifiedAt     DateTime?
  organizationId      String // Phase 1b: NOT NULL after backfill
  organization        Organization @relation(fields: [organizationId], references: [id])
  defaultClinicId     String? // UI default only — NOT used for authorization
  defaultClinic       Clinic?      @relation("UserDefaultClinic", fields: [defaultClinicId], references: [id])
  canAccessAllClinics Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  tasksCreated               Task[]                         @relation("TaskCreator")
  tasksAssigned              Task[]                         @relation("TaskAssignee")
  appointments               Appointment[]                  @relation("Practitioner")
  appointmentRequests        AppointmentRequest[]           @relation("AppointmentRequestPractitioner")
  contactRequestsAssigned    ContactRequest[]               @relation("ContactRequestAssignee")
  contactRequestsResolved    ContactRequest[]               @relation("ContactRequestResolver")
  availabilities             DoctorAvailability[]           @relation("DoctorAvailability")
  offDays                    DoctorOffDay[]                 @relation("DoctorOffDays")
  treatmentCases             TreatmentCase[]                @relation("Practitioner")
  insuranceAssigned          InsuranceProvision[]           @relation("InsuranceAssignedTo")
  insuranceCreated           InsuranceProvision[]           @relation("InsuranceCreatedBy")
  sentMessages               SentMessage[]
  createdTemplates           MessageTemplate[]              @relation("TemplateCreator")
  activityLogs               ActivityLog[]
  uploadedAttachments        PatientAttachment[]            @relation("AttachmentUploader")
  toothRecordsCreated        ToothRecord[]                  @relation("ToothRecordCreator")
  paymentPlans               PaymentPlan[]
  compensationRules          PractitionerCompensationRule[] @relation("PractitionerCompRules")
  serviceCompRules           ServiceCompensationRule[]      @relation("ServiceCompRules")
  practitionerEarnings       PractitionerEarning[]          @relation("PractitionerEarnings")
  practitionerPayouts        PractitionerPayout[]           @relation("PractitionerPayouts")
  payoutsCreated             PractitionerPayout[]           @relation("PayoutCreator")
  inventoryTransactions      InventoryTransaction[]         @relation("InventoryPerformedBy")
  proceduresCreated          TreatmentPlanProcedure[]       @relation("ProcedureCreator")
  packageApplicationsCreated TreatmentPackageApplication[]  @relation("TreatmentPackageApplicationCreator")
  userClinics                UserClinic[]
  resolvedInboxEntries       WhatsAppInboxEntry[]           @relation("InboxEntryResolver")
  resolvedInstagramEntries   InstagramInboxEntry[]          @relation("InstagramInboxEntryResolver")
  assignedRecallCandidates   RecallCandidate[]              @relation("RecallCandidateAssignee")
  performedRecallActions     RecallAction[]                 @relation("RecallActionPerformer")
  passwordResetTokens        PasswordResetToken[]
  emailVerificationTokens    EmailVerificationToken[]

  // Global uniqueness on lower(email) is enforced by a raw DB index (migration 20260629120000).
}

model DoctorAvailability {
  id             String   @id @default(uuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User     @relation("DoctorAvailability", fields: [practitionerId], references: [id])
  weekday        Int // 0 Sunday, 1 Monday, ... 6 Saturday
  startTime      String // HH:mm
  endTime        String // HH:mm
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clinicId, practitionerId, weekday])
}

model DoctorOffDay {
  id             String   @id @default(uuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User     @relation("DoctorOffDays", fields: [practitionerId], references: [id])
  date           String // YYYY-MM-DD (clinic local date)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clinicId, practitionerId, date])
  @@index([clinicId, practitionerId])
}

model Patient {
  id                   String       @id @default(uuid())
  clinicId             String
  clinic               Clinic       @relation(fields: [clinicId], references: [id])
  firstName            String
  lastName             String
  email                String?
  phone                String?
  dateOfBirth          DateTime?
  address              String?
  city                 String?
  postalCode           String?
  country              String?
  patientStatus        String       @default("new") // new, active, inactive, archived
  source               String? // google, referral, social_media, etc.
  notes                String?
  communicationConsent Boolean      @default(false)
  marketingConsent     Boolean      @default(false)
  organizationId       String // Phase 1b: NOT NULL after backfill
  organization         Organization @relation(fields: [organizationId], references: [id])
  primaryClinicId      String? // Default/preferred branch (not exclusive)
  primaryClinic        Clinic?      @relation("PatientPrimaryClinic", fields: [primaryClinicId], references: [id])
  // KVKK/GDPR anonymization tracking
  isAnonymized         Boolean      @default(false)
  anonymizedAt         DateTime?
  anonymizedById       String?
  anonymizationReason  String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?

  appointments                 Appointment[]
  appointmentRequests          AppointmentRequest[]
  contactRequests              ContactRequest[]
  treatmentCases               TreatmentCase[]
  tasks                        Task[]
  payments                     Payment[]
  insuranceProvisions          InsuranceProvision[]
  sentMessages                 SentMessage[]
  activityLogs                 ActivityLog[]
  whatsappConversationMessages WhatsAppConversationMessage[]
  attachments                  PatientAttachment[]
  toothRecords                 ToothRecord[]
  paymentPlans                 PaymentPlan[]
  practitionerEarnings         PractitionerEarning[]
  treatmentPlanProcedures      TreatmentPlanProcedure[]
  treatmentPackageApplications TreatmentPackageApplication[]
  patientClinics               PatientClinic[]
  whatsappInboxEntries              WhatsAppInboxEntry[]          @relation("InboxEntryPatient")
  instagramInboxEntries             InstagramInboxEntry[]         @relation("InstagramInboxEntryPatient")
  instagramConversationMessages     InstagramConversationMessage[]
  postTreatmentQueue                PostTreatmentMessageQueue[]
  recallCandidates                  RecallCandidate[]
  recallActions                     RecallAction[]
  privacyRequests                   PatientPrivacyRequest[]

  @@index([clinicId, phone])
  @@index([clinicId, email])
}

model AppointmentType {
  id              String   @id @default(uuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  name            String
  durationMinutes Int
  color           String?
  isActive        Boolean  @default(true)
  category        String?
  description     String?
  basePrice       Float?
  currency        String?
  isService       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments            Appointment[]
  appointmentRequests     AppointmentRequest[]
  treatmentCases          TreatmentCase[]
  serviceCompRules        ServiceCompensationRule[] @relation("ServiceCompRules")
  practitionerEarnings    PractitionerEarning[]     @relation("EarningService")
  treatmentPlanProcedures TreatmentPlanProcedure[]
  packageItems            TreatmentPackageItem[]
  materials               AppointmentTypeMaterial[]
  inventoryTransactions   InventoryTransaction[]    @relation("InventoryTransactionService")
  postTreatmentTemplates  PostTreatmentMessageTemplate[]
  postTreatmentQueue      PostTreatmentMessageQueue[]
}

model Appointment {
  id                 String          @id @default(uuid())
  clinicId           String
  clinic             Clinic          @relation(fields: [clinicId], references: [id])
  patientId          String
  patient            Patient         @relation(fields: [patientId], references: [id])
  practitionerId     String
  practitioner       User            @relation("Practitioner", fields: [practitionerId], references: [id])
  appointmentTypeId  String
  appointmentType    AppointmentType @relation(fields: [appointmentTypeId], references: [id])
  title              String?
  startTime          DateTime
  endTime            DateTime
  status             String          @default("scheduled") // scheduled, confirmed, completed, cancelled, no_show, etc.
  notes              String?
  cancellationReason String?
  noShowReason       String?
  // No-show recovery fields (Sprint 18)
  noShowMarkedAt     DateTime?
  noShowMarkedById   String?
  recoveryStatus     String? // unresolved | contacted | recovered
  recoveryNote       String?
  recoveredAt        DateTime?
  recoveredById      String?
  createdById        String?
  updatedById        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])

  tasks          Task[]
  sentMessages   SentMessage[]
  activityLogs   ActivityLog[]
  recallCandidates RecallCandidate[]
  recallActions    RecallAction[]
  sourceRequests AppointmentRequest[] @relation("ConvertedAppointment")
}

model AppointmentRequest {
  id                     String           @id @default(uuid())
  clinicId               String
  clinic                 Clinic           @relation(fields: [clinicId], references: [id])
  patientId              String?
  patient                Patient?         @relation(fields: [patientId], references: [id])
  patientName            String
  phone                  String
  email                  String?
  appointmentTypeId      String?
  appointmentType        AppointmentType? @relation(fields: [appointmentTypeId], references: [id])
  practitionerId         String?
  practitioner           User?            @relation("AppointmentRequestPractitioner", fields: [practitionerId], references: [id])
  preferredStartTime     DateTime?
  preferredEndTime       DateTime?
  requestType            String           @default("appointment") // appointment, reschedule, cancel, info
  source                 String           @default("whatsapp")
  externalSenderId       String?
  sourceConnectionId     String?
  sourceInboxEntryId     String?
  sourceConversationId   String?
  status                 String           @default("pending") // pending, approved, rejected, converted, closed
  rawMessage             String?
  notes                  String?
  rejectionReason        String?
  convertedAppointmentId String?
  convertedAppointment   Appointment?     @relation("ConvertedAppointment", fields: [convertedAppointmentId], references: [id])
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@index([clinicId, status, createdAt])
  @@index([clinicId, phone])
  @@index([clinicId, practitionerId])
  @@index([source, status, createdAt])
  @@index([sourceInboxEntryId])
}

model ContactRequest {
  id                    String    @id @default(uuid())
  clinicId              String
  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  patientId             String?
  patient               Patient?  @relation(fields: [patientId], references: [id])
  channel               String    // whatsapp, meta_whatsapp, instagram, manual
  sourceConversationId  String?
  sourceMessageId       String?
  externalSenderId      String?
  phone                 String?
  name                  String?
  type                  String    @default("staff_handoff") // callback_request, staff_handoff, information_request, complaint, other
  status                String    @default("pending")       // pending, in_progress, resolved, closed
  priority              String    @default("normal")        // normal, urgent
  note                  String?
  lastMessage           String?
  assignedToId          String?
  assignedTo            User?     @relation("ContactRequestAssignee", fields: [assignedToId], references: [id])
  resolvedById          String?
  resolvedBy            User?     @relation("ContactRequestResolver", fields: [resolvedById], references: [id])
  resolvedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([clinicId, status])
  @@index([clinicId, channel])
  @@index([clinicId, externalSenderId])
  @@index([clinicId, createdAt])
}

model WhatsAppConversationState {
  id                          String   @id @default(uuid())
  clinicId                    String
  clinic                      Clinic   @relation(fields: [clinicId], references: [id])
  phone                       String
  lastProviderMessageId       String?
  customerName                String?
  currentIntent               String?
  step                        String?
  selectedAppointmentTypeId   String?
  selectedAppointmentTypeName String?
  selectedPractitionerId      String?
  selectedDate                String?
  selectedTime                String?
  lastMessage                 String?
  stateJson                   Json?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([clinicId, phone])
  @@index([clinicId, updatedAt])
}

model WhatsAppConversationMessage {
  id                String   @id @default(uuid())
  clinicId          String
  clinic            Clinic   @relation(fields: [clinicId], references: [id])
  patientId         String
  patient           Patient  @relation(fields: [patientId], references: [id])
  phone             String
  providerMessageId String?
  direction         String
  text              String
  rawPayload        Json?
  createdAt         DateTime @default(now())

  @@unique([clinicId, providerMessageId])
  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, phone, createdAt])
}

model TreatmentCase {
  id                String           @id @default(uuid())
  clinicId          String
  clinic            Clinic           @relation(fields: [clinicId], references: [id])
  patientId         String
  patient           Patient          @relation(fields: [patientId], references: [id])
  practitionerId    String?
  practitioner      User?            @relation("Practitioner", fields: [practitionerId], references: [id])
  appointmentTypeId String?
  appointmentType   AppointmentType? @relation(fields: [appointmentTypeId], references: [id])
  title             String
  description       String?
  stage             String           @default("new") // new, quote_sent, in_progress, completed, lost
  estimatedAmount   Float?
  acceptedAmount    Float?
  currency          String?
  expectedStartDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  createdById       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  tasks                 Task[]
  appointments          Appointment[]
  payments              Payment[]
  insuranceProvisions   InsuranceProvision[]
  sentMessages          SentMessage[]
  activityLogs          ActivityLog[]
  paymentPlans          PaymentPlan[]
  practitionerEarnings  PractitionerEarning[]
  inventoryTransactions InventoryTransaction[]
  procedures            TreatmentPlanProcedure[]
  packageApplications   TreatmentPackageApplication[]
  recallCandidates      RecallCandidate[]
}

model TreatmentPackage {
  id              String   @id @default(uuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  name            String
  description     String?
  category        String?
  color           String?
  durationMinutes Int?
  price           Float?
  currency        String   @default("TRY")
  pricingMode     String   @default("PACKAGE_PRICE") // PACKAGE_PRICE | SERVICE_SUM
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items                 TreatmentPackageItem[]
  materials             TreatmentPackageMaterial[]
  applications          TreatmentPackageApplication[]
  procedures            TreatmentPlanProcedure[]
  inventoryTransactions InventoryTransaction[]
  postTreatmentTemplates PostTreatmentMessageTemplate[]
  postTreatmentQueue    PostTreatmentMessageQueue[]

  @@unique([clinicId, name])
  @@index([clinicId, isActive])
}

model TreatmentPackageItem {
  id                  String           @id @default(uuid())
  clinicId            String
  clinic              Clinic           @relation(fields: [clinicId], references: [id])
  packageId           String
  treatmentPackage    TreatmentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  serviceId           String
  service             AppointmentType  @relation(fields: [serviceId], references: [id])
  quantity            Int              @default(1)
  sortOrder           Int              @default(0)
  overridePrice       Float?
  overrideDurationMin Int?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  procedures TreatmentPlanProcedure[]

  @@unique([packageId, serviceId])
  @@index([clinicId])
  @@index([packageId])
  @@index([serviceId])
}

model AppointmentTypeMaterial {
  id              String          @id @default(uuid())
  clinicId        String
  clinic          Clinic          @relation(fields: [clinicId], references: [id])
  serviceId       String
  service         AppointmentType @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id])
  quantity        Float
  unit            String?
  deductionTiming String          @default("ON_TREATMENT_COMPLETED")
  isOptional      Boolean         @default(false)
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([serviceId, inventoryItemId])
  @@index([clinicId])
  @@index([serviceId])
  @@index([inventoryItemId])
}

model TreatmentPackageMaterial {
  id               String           @id @default(uuid())
  clinicId         String
  clinic           Clinic           @relation(fields: [clinicId], references: [id])
  packageId        String
  treatmentPackage TreatmentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  inventoryItemId  String
  inventoryItem    InventoryItem    @relation(fields: [inventoryItemId], references: [id])
  quantity         Float
  unit             String?
  deductionTiming  String           @default("ON_TREATMENT_COMPLETED")
  isOptional       Boolean          @default(false)
  note             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([packageId, inventoryItemId])
  @@index([clinicId])
  @@index([packageId])
  @@index([inventoryItemId])
}

model TreatmentPackageApplication {
  id                            String           @id @default(uuid())
  clinicId                      String
  clinic                        Clinic           @relation(fields: [clinicId], references: [id])
  treatmentCaseId               String
  treatmentCase                 TreatmentCase    @relation(fields: [treatmentCaseId], references: [id])
  patientId                     String
  patient                       Patient          @relation(fields: [patientId], references: [id])
  packageId                     String
  treatmentPackage              TreatmentPackage @relation(fields: [packageId], references: [id])
  pricingMode                   String
  totalDurationMinutes          Int?
  totalPrice                    Float?
  currency                      String?
  createdById                   String
  createdBy                     User             @relation("TreatmentPackageApplicationCreator", fields: [createdById], references: [id])
  extraMaterialsDeductedAt      DateTime?
  extraMaterialsDeductionStatus String?
  extraMaterialsDeductionError  String?
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt

  procedures            TreatmentPlanProcedure[]
  inventoryTransactions InventoryTransaction[]

  @@index([clinicId, treatmentCaseId])
  @@index([clinicId, packageId])
  @@index([clinicId, patientId])
}

model InsuranceProvision {
  id                          String         @id @default(uuid())
  clinicId                    String
  clinic                      Clinic         @relation(fields: [clinicId], references: [id])
  patientId                   String
  patient                     Patient        @relation(fields: [patientId], references: [id])
  treatmentCaseId             String?
  treatmentCase               TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  insuranceProviderName       String
  insuranceType               String
  policyNumber                String?
  provisionNumber             String?
  status                      String         @default("draft")
  requestedAmount             Float
  approvedAmount              Float?
  patientResponsibilityAmount Float?
  currency                    String         @default("TRY")
  submittedAt                 DateTime?
  respondedAt                 DateTime?
  rejectionReason             String?
  notes                       String?
  assignedToId                String?
  assignedTo                  User?          @relation("InsuranceAssignedTo", fields: [assignedToId], references: [id])
  createdById                 String
  createdBy                   User           @relation("InsuranceCreatedBy", fields: [createdById], references: [id])
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  activityLogs ActivityLog[]
}

model Task {
  id              String         @id @default(uuid())
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  patientId       String?
  patient         Patient?       @relation(fields: [patientId], references: [id])
  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  appointmentId   String?
  appointment     Appointment?   @relation(fields: [appointmentId], references: [id])
  assignedToId    String?
  assignedTo      User?          @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User           @relation("TaskCreator", fields: [createdById], references: [id])
  title           String
  description     String?
  dueDate         DateTime?
  status          String         @default("open") // open, in_progress, completed, cancelled
  priority        String         @default("normal") // low, normal, high, urgent
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  recallActions RecallAction[]
}

model Payment {
  id              String         @id @default(uuid())
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  amount          Float
  currency        String
  paymentMethod   String // cash, card, bank_transfer, etc.
  paymentStatus   String         @default("pending") // pending, partial, paid, refunded, cancelled
  paidAt          DateTime?
  notes           String?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sentMessages         SentMessage[]
  installment          PaymentPlanInstallment?
  practitionerEarnings PractitionerEarning[]
  recallCandidates     RecallCandidate[]
}

model MessageTemplate {
  id        String   @id @default(uuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  name      String
  channel   String // sms, whatsapp, email
  subject   String?
  body      String
  language  String   @default("en")
  isActive  Boolean  @default(true)
  purpose   String   @default("general_message") // appointment_reminder | payment_reminder | appointment_confirmation | no_show_recovery | post_treatment_followup | general_message
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation("TemplateCreator", fields: [createdById], references: [id])

  // Meta WhatsApp Template Management
  metaTemplateName            String?
  metaTemplateLanguage        String?
  metaTemplateCategory        String?   // utility, marketing, authentication
  metaTemplateStatus          String?   // draft, submitted, approved, rejected, paused, disabled, unknown
  metaTemplateId              String?
  metaTemplateRejectionReason String?
  metaTemplateLastSyncedAt    DateTime?
  metaTemplateSubmittedAt     DateTime?
  metaTemplateVariableMap     Json?

  sentMessages SentMessage[]
  recallCandidates RecallCandidate[]
}

model SentMessage {
  id                   String              @id @default(uuid())
  clinicId             String
  clinic               Clinic              @relation(fields: [clinicId], references: [id])
  patientId            String
  patient              Patient             @relation(fields: [patientId], references: [id])
  appointmentId        String?
  appointment          Appointment?        @relation(fields: [appointmentId], references: [id])
  treatmentCaseId      String?
  treatmentCase        TreatmentCase?      @relation(fields: [treatmentCaseId], references: [id])
  paymentId            String?
  payment              Payment?            @relation(fields: [paymentId], references: [id])
  templateId           String?
  template             MessageTemplate?    @relation(fields: [templateId], references: [id])
  channel              String
  recipient            String
  subject              String?
  body                 String
  status               String              @default("prepared") // prepared, sent, failed, delivered, read
  providerMessageId    String?
  sentAt               DateTime?
  createdById          String?
  createdBy            User?               @relation(fields: [createdById], references: [id])
  // Provider-agnostic WhatsApp extension fields
  organizationId       String?
  organization         Organization?       @relation(fields: [organizationId], references: [id])
  whatsappConnectionId String?
  whatsappConnection   WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id])
  provider             String? // evolution_api | meta_cloud_api
  direction            String? // outgoing | incoming
  externalMessageId    String? // Provider message ID for tracking
  createdAt            DateTime            @default(now())

  recallActions RecallAction[]
}

model ActivityLog {
  id                   String   @id @default(uuid())
  clinicId             String
  clinic               Clinic   @relation(fields: [clinicId], references: [id])
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
