// ── Provider-Agnostic WhatsApp Infrastructure ─────────────────────────────────

/// Organization-level WhatsApp connection. One connection can be shared by multiple branches.
model WhatsAppConnection {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  // evolution_api | meta_cloud_api
  provider       String       @default("evolution_api")
  // disconnected | connecting | connected | error
  status         String       @default("disconnected")
  phoneNumber    String?
  displayName    String?

  // Evolution API fields
  evolutionApiUrl          String?
  evolutionInstanceName    String? @unique
  // TODO: encrypt before storing (no encryption utility in this project yet)
  evolutionApiKeyEncrypted String?

  // Meta Cloud API foundation fields
  metaBusinessId           String?
  metaWabaId               String?
  metaPhoneNumberId        String?   @unique
  metaAppId                String?
  // TODO: encrypt before storing
  metaAccessTokenEncrypted String?
  metaWebhookVerifyToken   String?
  metaWebhookSecret        String?
  // Token lifecycle tracking — Meta tokens expire ~60 days unless refreshed
  // valid | expiring | expired | unknown
  metaTokenStatus          String?   @default("unknown")
  metaTokenExpiresAt       DateTime?
  metaTokenLastCheckedAt   DateTime?

  // Shared webhook secret for this connection
  webhookSecret   String?
  lastConnectedAt DateTime?
  lastError       String?
  isActive        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinics      ClinicWhatsAppConnection[]
  sentMessages SentMessage[]
  inboxEntries WhatsAppInboxEntry[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([provider])
}

/// Maps one WhatsAppConnection to one Clinic. Supports shared (one connection → many clinics)
/// and dedicated (one connection → one clinic) topology.
model ClinicWhatsAppConnection {
  id                   String             @id @default(uuid())
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id])
  clinicId             String
  clinic               Clinic             @relation(fields: [clinicId], references: [id])
  whatsappConnectionId String
  whatsappConnection   WhatsAppConnection @relation(fields: [whatsappConnectionId], references: [id])
  isDefault            Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([clinicId, whatsappConnectionId])
  @@index([organizationId])
  @@index([clinicId])
  @@index([whatsappConnectionId])
}

/// Incoming WhatsApp messages that could not be automatically assigned to a clinic.
/// Priority A-C resolution routes to existing flow; Priority D creates one of these.
/// After staff resolution: clinicId is set, needsClinicResolution=false, status=resolved.
model WhatsAppInboxEntry {
  id                    String              @id @default(uuid())
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id])
  whatsappConnectionId  String?
  whatsappConnection    WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id])
  clinicId              String? // null = unresolved
  clinic                Clinic?             @relation("InboxEntryClinic", fields: [clinicId], references: [id])
  patientId             String? // null = no matched patient yet
  patient               Patient?            @relation("InboxEntryPatient", fields: [patientId], references: [id])
  resolvedByUserId      String?
  resolvedBy            User?               @relation("InboxEntryResolver", fields: [resolvedByUserId], references: [id])
  phone                 String
  displayName           String?
  lastMessageText       String?
  messageCount          Int                 @default(1)
  externalMessageId     String?
  rawPayload            Json?
  needsClinicResolution Boolean             @default(false)
  // open | resolved
  status                String              @default("open")
  resolvedAt            DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([organizationId, needsClinicResolution])
  @@index([organizationId, status])
  @@index([organizationId, clinicId])
  @@index([whatsappConnectionId, phone])
}

// ── Sprint 13: Operational Monitoring ────────────────────────────────────────

/// Immutable audit trail of important admin/system actions.
/// Separate from ActivityLog (clinic-scoped, FK-heavy) — AuditLog is org-scoped
/// and designed for compliance, security reviews and operational investigations.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  clinicId       String?
  actorUserId    String?
  actorRole      String?
  action         String // user_login | branch_created | payment_created | ...
  entityType     String // user | branch | appointment | payment | whatsapp_connection | ...
  entityId       String?
  description    String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([clinicId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

/// System-level operational events: integration failures, webhook errors, etc.
/// Separate from AuditLog — these are monitorable / resolvable events.
model OperationalEvent {
  id             String    @id @default(uuid())
  organizationId String
  clinicId       String?
  // info | warning | error | critical
  severity       String    @default("info")
  // whatsapp | appointment | finance | auth | system
  source         String
  message        String
  metadata       Json?
  resolvedAt     DateTime?
  resolvedById   String?
  createdAt      DateTime  @default(now())

  @@index([organizationId, severity])
  @@index([organizationId, source])
  @@index([organizationId, resolvedAt])
  @@index([createdAt])
}

// ── Sprint 23: Instagram DM Integration ──────────────────────────────────────

/// Shared inbound message idempotency ledger for all messaging channels.
/// connectionId is intentionally provider-agnostic: it can reference WhatsAppConnection,
/// InstagramConnection, or a future channel-specific connection model.
model MessagingInboundEvent {
  id                     String    @id @default(uuid())
  channel                String
  provider               String
  connectionId           String?
  clinicId               String?
  organizationId         String?
  providerMessageId      String
  providerConversationId String?
  fromExternalId         String?
  toExternalId           String?
  fromPhone              String?
  toPhone                String?
  eventType              String    @default("message")
  direction              String    @default("inbound")
  status                 String    @default("received")
  rawPayload             Json?
  errorMessage           String?
  processedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([channel, provider, connectionId, providerMessageId])
  @@index([organizationId, status, createdAt])
  @@index([clinicId, status, createdAt])
  @@index([channel, provider, providerMessageId])
}

/// Organization-level Instagram DM connection. One connection can be shared by multiple branches.
/// Architecture: dedicated InstagramConnection model (Option B) to avoid disrupting WhatsApp.
model InstagramConnection {
  id                       String       @id @default(uuid())
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id])
  name                     String
  /// disconnected | connecting | connected | error
  status                   String       @default("disconnected")
  /// Meta Instagram webhook recipient/account id used for routing incoming DMs
  instagramAccountId       String?      @unique
  /// ID returned by Instagram Login API graph.instagram.com/me
  instagramLoginUserId     String?      @unique
  instagramUsername        String?
  facebookPageId           String?
  /// AES-256-GCM encrypted Meta access token
  accessTokenEncrypted     String?
  /// Page-scoped access token (if different from user token)
  pageAccessTokenEncrypted String?
  webhookVerifyToken       String?
  webhookSecret            String?
  metaAppId                String?
  metaBusinessId           String?
  /// valid | expiring | expired | unknown
  tokenStatus              String?      @default("unknown")
  tokenExpiresAt           DateTime?
  lastConnectedAt          DateTime?
  lastError                String?
  isActive                 Boolean      @default(true)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  clinics                      ClinicInstagramConnection[]
  inboxEntries                 InstagramInboxEntry[]
  conversationMessages         InstagramConversationMessage[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

/// Maps one InstagramConnection to one Clinic (shared or dedicated topology).
model ClinicInstagramConnection {
  id                    String              @id @default(uuid())
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id])
  clinicId              String
  clinic                Clinic              @relation(fields: [clinicId], references: [id])
  instagramConnectionId String
  instagramConnection   InstagramConnection @relation(fields: [instagramConnectionId], references: [id])
  isDefault             Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([clinicId, instagramConnectionId])
  @@index([organizationId])
  @@index([clinicId])
  @@index([instagramConnectionId])
}

/// Incoming Instagram DMs stored for staff review, patient linking, and appointment conversion.
/// Priority C (single-clinic) auto-assigns; Priority D creates an unresolved entry.
model InstagramInboxEntry {
  id                     String               @id @default(uuid())
  organizationId         String
  organization           Organization         @relation(fields: [organizationId], references: [id])
  instagramConnectionId  String?
  instagramConnection    InstagramConnection? @relation(fields: [instagramConnectionId], references: [id])
  clinicId               String?
  clinic                 Clinic?              @relation("InstagramInboxEntryClinic", fields: [clinicId], references: [id])
  patientId              String?
  patient                Patient?             @relation("InstagramInboxEntryPatient", fields: [patientId], references: [id])
  resolvedByUserId       String?
  resolvedBy             User?                @relation("InstagramInboxEntryResolver", fields: [resolvedByUserId], references: [id])
  /// Instagram sender IGSID (unique Instagram-scoped user ID)
  externalSenderId       String
  /// Instagram conversation/thread ID if provided
  externalConversationId String?
  senderUsername         String?
  lastMessageText        String?
  messageCount           Int                  @default(1)
  externalMessageId      String?
  rawPayload             Json?
  needsClinicResolution  Boolean              @default(false)
  /// open | resolved | ignored
  status                 String               @default("open")
  resolvedAt             DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([organizationId, needsClinicResolution])
  @@index([organizationId, status])
  @@index([organizationId, clinicId])
  @@index([instagramConnectionId, externalSenderId])
}

/// Individual Instagram DM messages (inbound + outbound) for conversation history.
model InstagramConversationMessage {
  id                    String               @id @default(uuid())
  organizationId        String
  organization          Organization         @relation(fields: [organizationId], references: [id])
  clinicId              String?
  clinic                Clinic?              @relation(fields: [clinicId], references: [id])
  patientId             String?
  patient               Patient?             @relation(fields: [patientId], references: [id])
  instagramConnectionId String?
  instagramConnection   InstagramConnection? @relation(fields: [instagramConnectionId], references: [id])
  externalSenderId      String
  senderUsername        String?
  externalMessageId     String?
  /// incoming | outgoing
  direction             String
  text                  String
  rawPayload            Json?
  createdAt             DateTime             @default(now())

  @@unique([organizationId, externalMessageId])
  @@index([organizationId, externalSenderId, createdAt])
  @@index([clinicId, patientId, createdAt])
}

/// Clinic-defined post-treatment message templates.
/// A single service/package can have multiple templates.
model PostTreatmentMessageTemplate {
  id                  String            @id @default(uuid())
  organizationId      String
  organization        Organization      @relation(fields: [organizationId], references: [id])
  clinicId            String
  clinic              Clinic            @relation(fields: [clinicId], references: [id])
  title               String
  /// service | package
  targetType          String
  serviceId           String?
  service             AppointmentType?  @relation(fields: [serviceId], references: [id])
  treatmentPackageId  String?
  treatmentPackage    TreatmentPackage? @relation(fields: [treatmentPackageId], references: [id])
  messageBody         String
  /// whatsapp | instagram | preferred
  channel             String            @default("preferred")
  sendDelayMinutes    Int               @default(0)
  requireStaffApproval Boolean         @default(false)
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  messageQueue PostTreatmentMessageQueue[]

  @@index([clinicId, isActive])
  @@index([clinicId, serviceId])
  @@index([clinicId, treatmentPackageId])
}

/// Queue of scheduled/sent post-treatment messages.
model PostTreatmentMessageQueue {
  id                            String                       @id @default(uuid())
  organizationId                String
  organization                  Organization                 @relation(fields: [organizationId], references: [id])
  clinicId                      String
  clinic                        Clinic                       @relation(fields: [clinicId], references: [id])
  patientId                     String
  patient                       Patient                      @relation(fields: [patientId], references: [id])
  templateId                    String
  template                      PostTreatmentMessageTemplate @relation(fields: [templateId], references: [id])
  appointmentId                 String?
  treatmentCaseId               String?
  treatmentProcedureId          String?
  treatmentPackageApplicationId String?
  serviceId                     String?
  service                       AppointmentType?             @relation(fields: [serviceId], references: [id])
  packageId                     String?
  treatmentPackage              TreatmentPackage?            @relation(fields: [packageId], references: [id])
  channel                       String
  recipient                     String?
  messageBodyRendered           String
  /// pending | sent | failed | cancelled | waiting_approval | no_recipient
  status                        String                       @default("pending")
  scheduledAt                   DateTime
  sentAt                        DateTime?
  errorMessage                  String?
  /// appointment_completed | procedure_completed | package_item_completed | package_completed
  sourceType                    String
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt

  /// Duplicate prevention: same template cannot be enqueued twice for same patient+source record
  @@unique([patientId, templateId, appointmentId, treatmentProcedureId])
  @@index([clinicId, status, scheduledAt])
  @@index([clinicId, patientId])
  @@index([templateId])
}

/// Global platform-level key-value settings (e.g. runtime feature toggles).
model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// KVKK/GDPR patient privacy rights requests (access, rectification, anonymization, etc.)
model PatientPrivacyRequest {
  id                 String    @id @default(uuid())
  clinicId           String
  clinic             Clinic    @relation(fields: [clinicId], references: [id])
  patientId          String?
  patient            Patient?  @relation(fields: [patientId], references: [id])
  /// access_export | rectification | anonymization | deletion_review | restriction | objection | other
  requestType        String
  /// pending | in_review | completed | rejected | cancelled
  status             String    @default("pending")
  requestedByUserId  String?
  handledByUserId    String?
  requestNote        String?
  decisionNote       String?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([clinicId, status])
  @@index([clinicId, patientId])
  @@index([clinicId, requestType])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ClinicLegalProfile {
  id                    String    @id @default(uuid())
  organizationId        String
  clinicId              String    @unique
  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  dataControllerTitle   String?
  taxNumber             String?
  mersisNumber          String?
  address               String?
  city                  String?
  country               String?   @default("TR")
  phone                 String?
  email                 String?
  privacyRequestEmail   String?
  kepEmail              String?
  website               String?
  dataProtectionContact String?
  privacyNoticeText     String?
  channelDisclosureText String?
  channelConsentText    String?
  privacyNoticeVersion  String?
  effectiveDate         DateTime?
  isPublished           Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([organizationId])
  @@index([clinicId])
}
