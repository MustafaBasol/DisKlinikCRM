/// Queue of scheduled/sent post-treatment messages.
model PostTreatmentMessageQueue {
  id                            String                       @id @default(uuid())
  organizationId                String
  organization                  Organization                 @relation(fields: [organizationId], references: [id])
  clinicId                      String
  clinic                        Clinic                       @relation(fields: [clinicId], references: [id])
  patientId                     String
  patient                       Patient                      @relation(fields: [patientId], references: [id])
  templateId                    String
  template                      PostTreatmentMessageTemplate @relation(fields: [templateId], references: [id])
  appointmentId                 String?
  treatmentCaseId               String?
  treatmentProcedureId          String?
  treatmentPackageApplicationId String?
  serviceId                     String?
  service                       AppointmentType?             @relation(fields: [serviceId], references: [id])
  packageId                     String?
  treatmentPackage              TreatmentPackage?            @relation(fields: [packageId], references: [id])
  channel                       String
  recipient                     String?
  messageBodyRendered           String
  /// pending | sent | failed | cancelled | waiting_approval | no_recipient
  status                        String                       @default("pending")
  scheduledAt                   DateTime
  sentAt                        DateTime?
  errorMessage                  String?
  /// appointment_completed | procedure_completed | package_item_completed | package_completed
  sourceType                    String
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt

  /// Duplicate prevention: same template cannot be enqueued twice for same patient+source record
  @@unique([patientId, templateId, appointmentId, treatmentProcedureId])
  @@index([clinicId, status, scheduledAt])
  @@index([clinicId, patientId])
  @@index([templateId])
}

