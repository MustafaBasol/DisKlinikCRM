  country               String?   @default("TR")
  phone                 String?
  email                 String?
  privacyRequestEmail   String?
  kepEmail              String?
  website               String?
  dataProtectionContact String?
  privacyNoticeText     String?
  channelDisclosureText String?
  channelConsentText    String?
  privacyNoticeVersion  String?
  effectiveDate         DateTime?
  isPublished           Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  noticeEvidences PublicBookingNoticeEvidence[]

  @@index([organizationId])
  @@index([clinicId])
}

/// Automatic evidence that a clinic's published Art. 10 privacy notice was
/// displayed to a public-booking visitor. This is NOT a consent record: no
/// acknowledgment action is required to create it, and it must never be
/// treated as proof of consent anywhere in the codebase. See
/// docs/compliance/KVKK_COMPLIANCE_AUDIT_AND_REMEDIATION.md (KVKK-CRIT-001a).
///
/// Snapshot fields exist because ClinicLegalProfile rows are mutable in
/// place (publish can be re-run to edit an already-published profile), so a
/// mutable FK alone would not preserve historical notice attribution.
model PublicBookingNoticeEvidence {
  id             String  @id @default(uuid())
  organizationId String
  clinicId       String
  clinic         Clinic  @relation(fields: [clinicId], references: [id])
  legalProfileId String?
  legalProfile   ClinicLegalProfile? @relation(fields: [legalProfileId], references: [id], onDelete: SetNull)

  /// Opaque per-tab/session identifier generated client-side (not a patient
  /// identifier) — used only to make bootstrap idempotent across re-renders
  /// and page refreshes within the same booking session.
  sessionId String

  /// SHA-256 hash of the opaque server-issued token the client must echo
  /// back with the booking submission. The raw token itself is returned to
  /// the client once and never persisted — only its hash is stored, so a
  /// database read cannot recover a usable token. Always server-generated —
  /// never trusted if supplied by the client anywhere else.
  tokenHash String @unique

  appointmentRequestId String?             @unique
  appointmentRequest   AppointmentRequest? @relation(fields: [appointmentRequestId], references: [id], onDelete: SetNull)

  noticeVersion       String
  noticeEffectiveDate DateTime?
  language            String   @default("tr")
  /// Fixed to "web_booking" for this flow; kept as a column (not a literal)
  /// so other future channels can reuse this table without a schema change.
  channel             String   @default("web_booking")
  /// Timestamp the server issued/delivered the notice payload to the
  /// client. This proves server-side delivery only, NOT that the visitor
  /// actually read or scrolled to the notice — never describe it as proof
  /// of reading or review anywhere in code, UI copy, or documentation.
  deliveredAt         DateTime @default(now())

  noticeTextSnapshot     String
  controllerNameSnapshot String
  privacyContactSnapshot String?
  noticeHash             String

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([clinicId, sessionId, channel])
  @@index([organizationId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model ChannelConsentLog {
  id                  String    @id @default(uuid())
  organizationId      String
  clinicId            String
  clinic              Clinic    @relation(fields: [clinicId], references: [id])
  channel             String // whatsapp | instagram
  contactIdentifier   String // normalized phone (WA) or externalSenderId (Instagram)
  conversationId      String? // conversation key or inbox entry id
  sourceMessageId     String? // provider message id of the consent reply
  consentStatus       String // accepted | declined
  consentTextVersion  String
  consentTextSnapshot String
  privacyUrl          String
  locale              String    @default("tr")
  acceptedAt          DateTime?
  declinedAt          DateTime?
  createdAt           DateTime  @default(now())

  @@index([clinicId, channel, contactIdentifier])
  @@index([clinicId, consentTextVersion])
  @@index([organizationId])
}

// ── Communication Preference & Consent Management (KVKK-HIGH-007) ─────────────
//
// Technical control only — not a legal determination. See
// docs/compliance/56-kvkk-communication-preference-and-consent-management.md.
//
// Two-table design:
//  - PatientCommunicationPreference: current effective state, one row per
//    patient+clinic+channel+purpose (fast lookup for every send decision;
//    upserted atomically so concurrent grant/withdraw races resolve to a
//    single deterministic row via the DB unique constraint).
//  - PatientCommunicationConsentEvent: immutable append-only history/evidence
//    of every state transition. Never updated or deleted by application code.
//
// This is separate from ChannelConsentLog, which records WhatsApp/Instagram
// inbound-reply opt-in to the Meta 24h messaging window (contact-identifier
// keyed, channel-only, no purpose dimension) — a narrower, provider-specific
// concern that predates this general-purpose model.

/// Current effective communication preference for one patient+clinic+channel+purpose.
/// Looked up by the central decision service (communicationConsentPolicy.ts) on
/// every send. A missing row means status = unknown (never implicitly granted).
model PatientCommunicationPreference {
  id             String   @id @default(uuid())
  organizationId String
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])

  /// sms | email | whatsapp | phone_call | push
  channel String
  /// transactional | appointment_reminder | appointment_followup | clinical_followup |
  /// recall | no_show_recovery | operational | marketing | campaign | survey |
  /// legal_notice | security_notice
  purpose String

  /// granted | denied | withdrawn | unknown | not_required
  status      String    @default("unknown")
  effectiveAt DateTime  @default(now())
  grantedAt   DateTime?
  withdrawnAt DateTime?
  expiresAt   DateTime?

  /// patient_portal | public_booking | staff | import | api | whatsapp |
  /// sms_keyword | email_unsubscribe | legacy | system
  source String

  /// Free-form evidence classification, e.g. verbal_staff_record | signed_form |
  /// portal_click | inbound_reply | public_booking_checkbox
  evidenceType String?
  /// Legal notice / KVKK text version shown at the time of the decision
  noticeVersion String?
  /// Internal policy/config version applied by the decision service
  policyVersion String?

  actorUserId          String?
  actorPlatformAdminId String?
  /// Hashed with COMMUNICATION_CONSENT_EVIDENCE_HASH_SECRET — never raw
  requestIpHash String?
  /// Hashed with COMMUNICATION_CONSENT_EVIDENCE_HASH_SECRET — never raw
  userAgentHash       String?
  externalProviderRef String?
  /// Sanitized, bounded free text — see consentEvidenceSanitizer.ts
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events PatientCommunicationConsentEvent[]

  @@unique([patientId, clinicId, channel, purpose])
  @@index([clinicId, channel, purpose, status])
  @@index([organizationId])
}

/// Immutable history/evidence record. One row is inserted every time a
/// PatientCommunicationPreference is created or its status changes. Rows are
/// never updated or deleted by application code (append-only audit trail).
model PatientCommunicationConsentEvent {
  id             String                         @id @default(uuid())
  organizationId String
  clinicId       String
  clinic         Clinic                         @relation(fields: [clinicId], references: [id])
  patientId      String
  patient        Patient                        @relation(fields: [patientId], references: [id])
  preferenceId   String
  preference     PatientCommunicationPreference @relation(fields: [preferenceId], references: [id])

  channel String
  purpose String

  previousStatus String?
  newStatus      String

  source               String
  evidenceType         String?
  noticeVersion        String?
  policyVersion        String?
  actorUserId          String?
  actorPlatformAdminId String?
  requestIpHash        String?
  userAgentHash        String?
  externalProviderRef  String?
  notes                String?

  createdAt DateTime @default(now())

  @@index([patientId, clinicId, channel, purpose, createdAt])
  @@index([clinicId, createdAt])
  @@index([organizationId])
}

// ── SMS Add-on Module ─────────────────────────────────────────────────────────

/// Per-clinic SMS add-on configuration. SMS is DISABLED unless addonEnabled=true
/// here or the clinic/organization plan has features.sms === true.
model ClinicSmsSettings {
  id                   String   @id @default(uuid())
  organizationId       String
  clinicId             String   @unique
  clinic               Clinic   @relation(fields: [clinicId], references: [id])
  /// Clinic-level add-on activation (managed by platform admin, sold as package)
  addonEnabled         Boolean  @default(false)
  /// Monthly outbound SMS quota. 0 = no sending allowed even when enabled.
  monthlyQuota         Int      @default(0)
  /// Alphanumeric sender id / originator shown to recipients (provider-dependent)
  senderName           String?
  /// Provider key for Turkish numbers (e.g. mock_turkey; real providers later)
  turkeyProvider       String?
  turkeyProviderConfig Json?
  /// Provider key for European numbers (e.g. mock_europe; real providers later)
  europeProvider       String?
  europeProviderConfig Json?
  /// Destination-region permissions, set only by platform admin. Off by
  /// default for newly-enabled add-ons; existing active clinics were
  /// backfilled to true when this column was introduced (see migration
  /// 20260703100000_add_sms_clinic_routing_policy).
  turkeyAllowed        Boolean  @default(false)
  europeAllowed        Boolean  @default(false)
  /// automatic_by_recipient_phone_region | force_turkey_provider | force_europe_provider
  routingPolicy        String   @default("automatic_by_recipient_phone_region")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([organizationId])
}

/// Outbound SMS queue + clinic-scoped history. One row per send attempt,
/// including sends blocked by quota/consent/region so staff can see why.
model SmsMessage {
  id                String           @id @default(uuid())
  organizationId    String
  clinicId          String
  clinic            Clinic           @relation(fields: [clinicId], references: [id])
  patientId         String?
  patient           Patient?         @relation(fields: [patientId], references: [id])
  appointmentId     String?
  appointment       Appointment?     @relation(fields: [appointmentId], references: [id])
  templateId        String?
  template          MessageTemplate? @relation("SmsMessageTemplate", fields: [templateId], references: [id])
  /// appointment_confirmation | appointment_reminder | appointment_cancellation |
  /// appointment_reschedule | no_show_recovery | post_treatment_followup |
  /// manual_message | payment_reminder | marketing
  purpose           String
  /// Normalized E.164 recipient (no other personal data duplicated here)
  recipient         String
  body              String
  /// queued | sent | delivered | failed | blocked_addon | blocked_quota |
  /// blocked_consent | blocked_region | blocked_template
  status            String           @default("queued")
  /// tr | eu | unsupported — routing decision snapshot
  providerRegion    String?
  /// Provider key that handled (or would handle) the message
  provider          String?
  externalMessageId String?
  errorCode         String?
  errorMessage      String?
  /// Duplicate prevention key (e.g. purpose+appointment+date); unique when set
  dedupeKey         String?          @unique
  queuedAt          DateTime         @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdById       String?
  createdBy         User?            @relation("SmsMessageCreator", fields: [createdById], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([clinicId, status, createdAt])
  @@index([clinicId, patientId])
  @@index([organizationId])
}

/// Atomic per-clinic monthly usage counter (period = "YYYY-MM").
/// Incremented with a guarded update so concurrent sends cannot exceed quota.
model SmsUsageCounter {
  id        String   @id @default(uuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  period    String
  sentCount Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([clinicId, period])
}

/// Platform-level SMS provider configuration, managed only by platform admins.
/// Clinics never see or edit these rows; sending falls back to the region's
/// default platform provider when a clinic has no explicit provider override.
model PlatformSmsProvider {
  id            String    @id @default(uuid())
  /// Routing region: tr | eu
  region        String
  /// Adapter key in the provider registry (e.g. mock_turkey, netgsm, twilio)
  providerCode  String
  displayName   String
  isActive      Boolean   @default(false)
  /// Default provider for the region when a clinic has no explicit override
  isDefault     Boolean   @default(false)
  /// Alphanumeric sender id / originator, when the provider supports it
  senderName    String?
  /// API credentials encrypted via encryptJson() — never returned by the API
  credentials   Json?
  lastTestedAt  DateTime?
  lastTestOk    Boolean?
  lastTestError String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([region, providerCode])
  @@index([region, isActive, isDefault])
}

// ── Dental Laboratory Tracking ─────────────────────────────────────────────────

model Laboratory {
  id            String    @id @default(uuid())
  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id])
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  isActive      Boolean   @default(true)
  createdById   String?
  createdBy     User?     @relation("LaboratoryCreator", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  labWorkOrders LabWorkOrder[]

  @@index([clinicId, isActive])
}

model LabWorkOrder {
  id              String         @id @default(uuid())
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  laboratoryId    String
  laboratory      Laboratory     @relation(fields: [laboratoryId], references: [id])
  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  practitionerId  String?
  practitioner    User?          @relation("LabWorkOrderPractitioner", fields: [practitionerId], references: [id])

  // Work item classification
  workType      String // crown, bridge, denture_full, denture_partial, implant_prosthetic,
  // night_guard, aligner, retainer, repair, temp_prosthetic, other
  toothFdi      String? // comma-separated FDI codes or range, free text (multi-tooth cases)
  shade         String?
  material      String?
  notesForLab   String?
  notesInternal String?

  // Status flow: pending -> impression_taken -> sent_to_lab -> in_progress -> received_from_lab
  //   -> fitting_or_trial -> revision_requested (loops back to sent_to_lab) -> completed
  // cancelled reachable from any non-completed status
  status        String @default("pending")
  revisionCount Int    @default(0)

  impressionTakenAt  DateTime?
  sentToLabAt        DateTime?
  expectedReturnDate DateTime?
  receivedFromLabAt  DateTime?
  fittingScheduledAt DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancelReason       String?

  // Clinic's own reference only — no invoicing/billing integration
  labCost  Float?
  currency String? // USD | EUR | TRY | GBP | CAD | CHF

  createdById String
  createdBy   User      @relation("LabWorkOrderCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  attachments   LabOrderAttachment[]
  statusHistory LabWorkOrderStatusHistory[]

  @@index([clinicId, status])
  @@index([clinicId, patientId])
  @@index([clinicId, laboratoryId])
  @@index([clinicId, expectedReturnDate])
}

// Append-only audit trail of status transitions (incl. remake loop-backs), kept
// separate from the generic ActivityLog so the UI can render a compact per-order
// timeline without joining ActivityLog's generic entityType/entityId rows.
model LabWorkOrderStatusHistory {
  id             String       @id @default(uuid())
  labWorkOrderId String
  labWorkOrder   LabWorkOrder @relation(fields: [labWorkOrderId], references: [id])
  fromStatus     String?
  toStatus       String
  note           String?
  changedById    String
  changedBy      User         @relation("LabWorkOrderStatusChanger", fields: [changedById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([labWorkOrderId, createdAt])
}

model LabOrderAttachment {
  id             String       @id @default(uuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id])
  labWorkOrderId String
  labWorkOrder   LabWorkOrder @relation(fields: [labWorkOrderId], references: [id])
  fileName       String
  originalName   String
  fileSize       Int
  mimeType       String
  filePath       String
  uploadedById   String
  uploadedBy     User         @relation("LabOrderAttachmentUploader", fields: [uploadedById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([clinicId, labWorkOrderId])
}

// ─── Imaging / Device Integration Foundation (Phase 1) ─────────────────────
// Standards-first temel: modality kodları DICOM'dan esinlenir, UID alanları
// gelecekteki DICOMweb/PACS entegrasyonu için nullable tutulur. Orijinal
// görüntüler değişmezdir (immutable) — binary güncelleme/silme endpoint'i yok;
// arşivleme yalnızca ImagingStudy.status'u değiştirir.

model ImagingDevice {
  id             String   @id @default(uuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  name           String
  modality       String // IO | PX | CT | CEPH | IO_CAMERA | SCANNER | OTHER
  manufacturer   String?
  modelName      String?
  connectionType String   @default("manual") // manual | bridge | dicomweb (bridge/dicomweb: gelecek fazlar)
  isActive       Boolean  @default(true)
  notes          String?
  createdById    String
  createdBy      User     @relation("ImagingDeviceCreator", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  imagingRequests ImagingRequest[]
  imagingStudies  ImagingStudy[]

  @@index([clinicId, isActive])
}

// Minimal çekim istemi (acquisition job) — gelecekte DICOM Modality Worklist
// ve köprü (bridge) işleri bu modele bağlanır.
model ImagingRequest {
  id                String         @id @default(uuid())
  clinicId          String
  clinic            Clinic         @relation(fields: [clinicId], references: [id])
  patientId         String
  patient           Patient        @relation(fields: [patientId], references: [id])
  appointmentId     String?
  appointment       Appointment?   @relation(fields: [appointmentId], references: [id])
  treatmentCaseId   String?
  treatmentCase     TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  requestedModality String // IO | PX | CT | CEPH | IO_CAMERA | SCANNER | OTHER
  requestedDeviceId String?
  requestedDevice   ImagingDevice? @relation(fields: [requestedDeviceId], references: [id])
  status            String         @default("requested") // requested | scheduled | received | cancelled | failed
  priority          String? // routine | urgent
  notes             String?
  requestedByUserId String
  requestedBy       User           @relation("ImagingRequestRequester", fields: [requestedByUserId], references: [id])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  imagingStudies ImagingStudy[]

  @@index([clinicId, status])
  @@index([clinicId, patientId])
}

model ImagingStudy {
  id               String              @id @default(uuid())
  clinicId         String
  clinic           Clinic              @relation(fields: [clinicId], references: [id])
  patientId        String? // NULL ⇒ bağlanmamış kuyruğu (unlinked queue)
  patient          Patient?            @relation(fields: [patientId], references: [id])
  appointmentId    String?
  appointment      Appointment?        @relation(fields: [appointmentId], references: [id])
  treatmentCaseId  String?
  treatmentCase    TreatmentCase?      @relation(fields: [treatmentCaseId], references: [id])
  deviceId         String?
  device           ImagingDevice?      @relation(fields: [deviceId], references: [id])
  imagingRequestId String?
  imagingRequest   ImagingRequest?     @relation(fields: [imagingRequestId], references: [id])
  modality         String // IO | PX | CT | CEPH | IO_CAMERA | SCANNER | OTHER
  studyDate        DateTime            @default(now())
  description      String?
  source           String              @default("manual_upload") // manual_upload | bridge | import
  status           String              @default("active") // active | archived — tanısal veri hiç hard-delete edilmez
  studyInstanceUid String? // DICOMweb-uyumluluk için; manuel yüklemede boş kalır
  // Bridge yüklemelerinin kullanıcı aktörü yoktur — createdById bu yüzden nullable.
  createdById      String?
  createdBy        User?               @relation("ImagingStudyCreator", fields: [createdById], references: [id])
  bridgeAgentId    String? // source: 'bridge' olan çalışmalarda provenance; unique constraint'in parçası DEĞİL
  bridgeAgent      ImagingBridgeAgent? @relation(fields: [bridgeAgentId], references: [id])
  // Bridge ingest idempotency: ajanın gönderdiği sha256, sunucuda yeniden
  // hesaplanıp doğrulanır (bkz. routes/imagingBridgePublic.ts). clinicId ile
  // birlikte tekilleştirilir — bridgeAgentId ile DEĞİL, böylece ajan
  // değişse/çoğalsa bile aynı dosya iki kez yüklenemez. Manuel yüklemelerde
  // NULL kalır (Postgres NULL'ları unique constraint'te çakıştırmaz).
  ingestKey        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  /// KVKK lifecycle (docs/compliance/53): blocks anonymization metadata
  /// redaction of every image under this study. Images do not carry their
  /// own legal-hold field — they inherit the study's. Set only via the
  /// legal-hold PATCH endpoint (OWNER/ORG_ADMIN); no automatic trigger.
  legalHold       Boolean @default(false)
  legalHoldReason String?

  images ImagingImage[]

  @@unique([clinicId, ingestKey])
  @@index([clinicId, patientId])
  @@index([clinicId, status])
  @@index([clinicId, legalHold])
}

// Yerel klinik köprü ajanı (bridge/agent) kayıt + heartbeat sözleşmesi.
// Phase 2'de yalnızca kayıt/iptal/heartbeat vardır; iş çekme (job polling)
// ve görüntü yükleme gelecek fazların işidir (docs/47).
// tokenHash: köprü token'ının sha256 hex özeti — düz metin token yalnızca
// oluşturma yanıtında BİR KEZ gösterilir, asla saklanmaz/loglanmaz.
model ImagingBridgeAgent {
  id           String    @id @default(uuid())
  clinicId     String
  clinic       Clinic    @relation(fields: [clinicId], references: [id])
  name         String
  tokenHash    String    @unique
  status       String    @default("pending") // pending | online | offline | revoked
  lastSeenAt   DateTime?
  agentVersion String?
  createdById  String
  createdBy    User      @relation("ImagingBridgeAgentCreator", fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Windows self-service bridge metadata (docs/spec: self-service imaging bridge).
  // Never store: Windows username, raw hardware serial, MAC address, full local
  // paths, original file names, patient identity.
  installationId         String?   @unique
  machineIdHash          String? // risk/diagnostic signal only — never an auth mechanism
  computerDisplayName    String?
  osVersion              String?
  architecture           String?
  capabilities           Json?
  pendingCount           Int       @default(0)
  failedCount            Int       @default(0)
  lastSuccessfulUploadAt DateTime?
  lastErrorCategory      String?
  updateChannel          String    @default("stable")
  lastUpdateCheckAt      DateTime?
  createdWithPairingId   String?   @unique

  imagingStudies     ImagingStudy[]
  bindings           ImagingBridgeBinding[]
  createdWithPairing ImagingBridgePairing?  @relation("PairingCreatedAgent", fields: [createdWithPairingId], references: [id])

  @@index([clinicId])
}

// Short-lived, single-use pairing session created from the authenticated web
// app and redeemed once by the Windows Manager app. Plaintext code is never
// stored — only an HMAC-SHA256 hash (server-side pepper, see codeHash below).
model ImagingBridgePairing {
  id            String    @id @default(uuid())
  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id])
  createdById   String
  createdBy     User      @relation("ImagingBridgePairingCreator", fields: [createdById], references: [id])
  codeHash      String    @unique // HMAC-SHA256(code, IMAGING_BRIDGE_PAIRING_PEPPER)
  status        String    @default("pending") // pending | redeemed | expired | cancelled | locked
  expiresAt     DateTime
  usedAt        DateTime?
  cancelledAt   DateTime?
  attemptCount  Int       @default(0)
  maxAttempts   Int       @default(5)
  bridgeName    String
  bridgeAgentId String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  devices      ImagingBridgePairingDevice[]
  createdAgent ImagingBridgeAgent?          @relation("PairingCreatedAgent")

  @@index([clinicId])
  @@index([expiresAt])
}

model ImagingBridgePairingDevice {
  id        String               @id @default(uuid())
  pairingId String
  pairing   ImagingBridgePairing @relation(fields: [pairingId], references: [id], onDelete: Cascade)
  deviceId  String
  modality  String
  createdAt DateTime             @default(now())

  @@unique([pairingId, deviceId])
}

// Represents one imaging device connected through an installed bridge agent.
// Local folder paths are intentionally NOT stored server-side.
model ImagingBridgeBinding {
  id                String             @id @default(uuid())
  clinicId          String
  clinic            Clinic             @relation(fields: [clinicId], references: [id])
  bridgeAgentId     String
  bridgeAgent       ImagingBridgeAgent @relation(fields: [bridgeAgentId], references: [id])
  deviceId          String
  modality          String
  displayName       String
  acquisitionType   String             @default("folder_watch")
  status            String             @default("pending") // pending | active | error | disabled
  lastValidatedAt   DateTime?
  lastErrorCategory String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([bridgeAgentId, deviceId])
  @@index([clinicId])
}

model ImagingImage {
  id             String       @id @default(uuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id])
  studyId        String
  study          ImagingStudy @relation(fields: [studyId], references: [id])
  fileName       String
  originalName   String
  fileSize       Int
  mimeType       String
  filePath       String // depolama anahtarı (fileStorage.ts) — asla public URL üretilmez
  sopInstanceUid String? // DICOM-uyumluluk için; manuel yüklemede boş kalır
  createdAt      DateTime     @default(now())

  /// See PatientAttachment.storageVerifiedMissingAt — same semantics, set by
  /// the orphan-check inspection when the physical file is missing.
  storageVerifiedMissingAt DateTime?

  @@index([clinicId, studyId])
}

/// KVKK lifecycle (docs/compliance/53): short-lived, downloadable ZIP package
/// generated by POST /patients/:id/privacy/export-package. Follows the same
/// token-hash + expiry pattern as PublicBookingNoticeEvidence — the raw
/// download token is returned once and never persisted, only its SHA-256
/// hash. Rows (and their physical ZIP file) are deleted by a dedicated
/// cleanup job once expiresAt has passed, regardless of downloadedAt — this
/// is a short-lived transfer artifact, not an audit record. The durable
/// record of a download is the AuditLog entry written at download time.
model PatientPrivacyExportArchive {
  id                String    @id @default(uuid())
  organizationId    String
  clinicId          String
  clinic            Clinic    @relation(fields: [clinicId], references: [id])
  patientId         String
  requestedByUserId String
  requestedByUser   User      @relation("PrivacyExportRequester", fields: [requestedByUserId], references: [id])

  /// Lifecycle state: queued -> generating -> ready | failed. A row is
  /// created with status="generating" BEFORE the (potentially slow) ZIP
  /// build starts, so a concurrent request for the same clinic can be
  /// rejected with 409 rather than racing to build two exports at once. Rows
  /// older than the in-flight staleness window (see
  /// patientPrivacyExportPackage.ts) are treated as abandoned/failed, not as
  /// a permanent lock.
  status String @default("ready")

  /// Storage key under exports/<clinicId>/<uuid>.zip (fileStorage.ts) —
  /// never serialized to any API response. Null while status="generating".
  storageKey String?
  /// Manifest described in docs/compliance/53 (exportVersion, includedFiles
  /// w/ sha256, missingFiles, skippedFiles). Null while status="generating".
  manifestJson Json?

  /// SHA-256 hash of the opaque one-time download token. Raw token is
  /// returned once to the caller and never persisted. Null while
  /// status="generating".
  tokenHash String? @unique

  expiresAt    DateTime?
  downloadedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  /// Lease/heartbeat (replaces createdAt-based staleness — an export can
  /// legitimately run for a long time up to EXPORT_MAX_TOTAL_SIZE_BYTES).
  /// heartbeatAt is renewed periodically by the running generation; the
  /// stale sweep in reserveGenerationSlot only fails a row once
  /// leaseExpiresAt has passed, never merely because it is old.
  heartbeatAt    DateTime?
  leaseExpiresAt DateTime?

  @@index([clinicId, patientId])
  @@index([organizationId])
  @@index([expiresAt])
  @@index([clinicId, status])
  @@index([clinicId, status, leaseExpiresAt])
}

/// KVKK-HIGH-004 (docs/compliance/54): clinic-scoped structured-data bulk export.
/// OWNER/ORG_ADMIN only, step-up authenticated, feature-flagged off by default,
/// asynchronously generated and streamed. Never contains physical
/// attachment/imaging bytes (see docs/compliance/54 scope decision).
///
/// Lifecycle: queued -> generating -> ready -> expired, or -> failed at any
/// point before ready. "expired" is a real stored terminal status, never
/// derived ad hoc from expiresAt — every route that reads this row (status,
/// download-token issuance, download) calls the single shared
/// expireArchiveIfPastTtl() helper first, so a ready row past its expiresAt
/// is always caught synchronously, regardless of whether the 15-minute
/// cleanup cron has run yet (cleanup-cron timing must never be part of the
/// security decision — see clinicBulkExportPackage.ts).
///
/// Exactly one queued/generating row may exist per clinic at a time. This is
/// enforced twice: (1) an advisory-lock-guarded reservation transaction in
/// application code, and (2) as the final invariant, a hand-written partial
/// unique index added via raw SQL in the migration (Prisma schema has no
/// first-class partial-unique-index syntax without an unstable preview
/// feature):
///   CREATE UNIQUE INDEX "ClinicBulkExportArchive_one_active_per_clinic"
///   ON "ClinicBulkExportArchive" ("clinicId")
///   WHERE status IN ('queued', 'generating');
/// See migration 20260716120000_clinic_bulk_export for the raw SQL and
/// docs/compliance/54 for the fresh-DB drift validation notes.
///
/// Storage-object deletion is deliberately NOT part of the same operation as
/// the ready->expired status transition (a Postgres transaction cannot span
/// an S3/local filesystem delete). artifactDeletedAt/cleanupFailureCode
/// track that separate, retryable step — see clinicBulkExportPackage.ts.
model ClinicBulkExportArchive {
  id                String        @id @default(uuid())
  organizationId    String
  clinicId          String
  clinic            Clinic        @relation(fields: [clinicId], references: [id])
  /// Nullable + SetNull (not a required relation): archive/audit history must
  /// survive the requesting user being deactivated/deleted later.
  requestedByUserId String?
  requestedByUser   User?         @relation("ClinicBulkExportRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  /// The user whose password most recently satisfied step-up for THIS
  /// archive (creation, or a fresh re-verification at download-token
  /// issuance). Binds the STEP_UP_WINDOW_MS reuse window to a specific
  /// actor — download-token issuance without a fresh password is only
  /// permitted when the current authenticated user matches this field AND
  /// stepUpVerifiedAt is still within the window. A different OWNER/
  /// ORG_ADMIN may still obtain a token, but only after verifying their OWN
  /// current password (which then overwrites both fields). Nullable +
  /// SetNull so archive history survives the verifying user being
  /// deactivated/deleted — a null value can never satisfy passwordless
  /// window reuse for anyone.
  stepUpVerifiedByUserId String?
  stepUpVerifiedByUser   User?         @relation("ClinicBulkExportStepUpVerifier", fields: [stepUpVerifiedByUserId], references: [id], onDelete: SetNull)

  status String @default("queued") // queued | generating | ready | failed | expired

  purpose        String // regulatory_request | clinic_migration | contract_termination | legal_request | other
  /// Internal note only. Never copied into AuditLog, OperationalEvent, or any log line.
  restrictedNote String?

  exportSchemaVersion Int @default(1)

  /// Object-storage key under exports/<clinicId>/<uuid>.zip. Never serialized
  /// to any API response. Preserved (not nulled) on a failed storage-delete
  /// attempt so the next cleanup run can retry — see cleanupFailureCode.
  storageKey String?
  /// Manifest (see docs/compliance/54): schemaVersion, entityCounts,
  /// fileNames, sha256PerFile, scopeDescription. Only ever written for a
  /// successfully completed job — never partially written on failure.
  manifestJson Json?

  /// SHA-256 hash of the opaque one-time download token. Raw token is
  /// returned once and never persisted. Issuance is atomic: guarded by
  /// status='ready' AND downloadTokenHash IS NULL so exactly one concurrent
  /// issuance request can win (see clinicBulkExportPackage.ts).
  downloadTokenHash String? @unique

  /// Server-recorded step-up timestamp (creation time, or refreshed at
  /// download-token issuance if a fresh password was supplied). Never a
  /// client-supplied timestamp — see STEP_UP_WINDOW_MS in passwordStepUp.ts.
  stepUpVerifiedAt DateTime?

  expiresAt    DateTime?
  downloadedAt DateTime?

  /// Set once the storage object has actually been deleted (separate,
  /// retryable step from the ready->expired status transition).
  artifactDeletedAt  DateTime?
  /// Set when a storage-delete attempt fails, so the next cleanup run knows
  /// to retry using the still-present storageKey rather than assuming the
  /// object is gone. Cleared once deletion succeeds. Stable code only
  /// (e.g. "STORAGE_DELETE_FAILED") — never raw exception text.
  cleanupFailureCode String?

  /// Lease/heartbeat — an abandoned generating row (crashed worker) becomes
  /// failed once leaseExpiresAt passes, never merely because it is old.
  heartbeatAt    DateTime?
  leaseExpiresAt DateTime?

  /// Stable failure code only (e.g. "SIZE_LIMIT_EXCEEDED", "LEASE_EXPIRED",
  /// "GENERATION_ERROR"). Never raw exception text, SQL, or a local path.
  failureCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, clinicId])
  @@index([clinicId, status])
  @@index([requestedByUserId, createdAt])
  @@index([stepUpVerifiedByUserId])
  @@index([expiresAt])
  @@index([leaseExpiresAt])
  @@index([clinicId, status, leaseExpiresAt])
}

/// KVKK-HIGH-004 step-up brute-force lockout — PostgreSQL-authoritative.
/// Every check-and-increment for a given (userId, clinicId, ipHash) key is
/// serialized with pg_advisory_xact_lock (same key-derivation shape as
/// appointmentRequestSafety.ts) acquired BEFORE reading/creating the row, so
/// concurrent first-attempts for a brand-new key cannot race. Redis
/// (createRateLimiter) may add an optional fast pre-check ahead of this
/// table, but this table is the single source of truth for lockout state —
/// never a second independent counter. ipHash is HMAC-SHA256 of the client
/// IP keyed by the dedicated CLINIC_BULK_EXPORT_IP_HASH_SECRET (never the
/// raw IP, never a shared/reused app secret). Rows untouched for >30 days
/// are deleted by the cleanup job.
model ClinicBulkExportPasswordAttempt {
  id              String    @id @default(uuid())
  userId          String
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  ipHash          String
  attemptCount    Int       @default(0)
  windowStartedAt DateTime  @default(now())
  lockedUntil     DateTime?
  updatedAt       DateTime  @updatedAt

  @@unique([userId, clinicId, ipHash])
  @@index([updatedAt])
}

// ── KVKK-CRIT-003: Security Incident Response Foundation ────────────────────
//
// This is a TECHNICAL foundation only. It does not constitute legal approval
// of breach classification, notification obligations/deadlines/recipients,
// legal wording, or regulator/data-subject communication — see
// docs/compliance/55-kvkk-security-incident-response-foundation.md.
//
// Three models, three distinct jobs — never merge them:
//   SecuritySignalEvent      — append-only raw detection evidence. Never
//                              mutated. What windowed-threshold counting
//                              reads FROM.
//   SecurityIncident         — the mutable, deduplicated aggregate a
//                              Platform Admin actually works. incidentKey
//                              is unique so concurrent identical signals
//                              can only ever produce one row (DB-level
//                              upsert, never find-then-create).
//   SecurityIncidentActivity — immutable per-incident history. Only ever
//                              inserted, in the same transaction as the
//                              SecurityIncident row it documents.

/// Append-only raw security-signal evidence. Deliberately NOT layered onto
/// the existing OperationalEvent model: OperationalEvent.organizationId is a
/// required (non-nullable) column depended on by 8+ existing org-scoped call
/// sites and the clinic-facing /api/ops/events route, but some security
/// signals (a Platform Admin login failure, a cross-tenant probe with no
/// resolvable target org) have no natural single organizationId — forcing
/// them through OperationalEvent would mean either a risky nullability
/// change to a widely-depended-on column or a fake placeholder org id, both
/// worse than a dedicated table. Never contains secrets, tokens, raw IPs, or
/// patient content — see securitySignalService.ts's allowlist sanitizer.
model SecuritySignalEvent {
  id String @id @default(uuid())

  signalType String // e.g. "auth_login_failed", "clinic_scope_denied", "export_step_up_lockout"
  category   String
  severity   String
  ruleKey    String

  organizationId String?
  clinicId       String?

  actorUserId          String?
  actorPlatformAdminId String?

  /// HMAC-SHA256(SECURITY_SIGNAL_IP_HASH_SECRET, ip) — never a raw IP.
  ipHash String?
  /// Bounded/normalized user-agent fingerprint (hashed) — never the raw header.
  userAgentFingerprint String?

  resourceType String?
  /// HMAC-hashed or otherwise safe resource identifier — never a raw guessed id.
  resourceId   String?

  /// Grouping key used to compute a durable windowed occurrence count for
  /// threshold-based rules (e.g. an account-identifier hash, an ipHash, or a
  /// resource-scope hash) — see securitySignalService.ts.
  dedupeDimension String

  /// Sanitized metadata only — allowlist-checked, see securitySignalService.ts.
  safeMetadata Json?

  createdAt DateTime @default(now())

  @@index([ruleKey, dedupeDimension, createdAt])
  @@index([organizationId, createdAt])
  @@index([clinicId, createdAt])
  @@index([createdAt])
}

/// Durable, deduplicated security incident record — the mutable aggregate a
/// Platform Admin actually triages and works. legalReviewRequired/
/// legalReviewStatus are technical placeholders recording that a human
/// legal decision is pending; they are never set by this feature to imply a
/// legal conclusion, classification, or notification deadline — see the
/// runbook. onDelete: SetNull throughout so a deleted/deactivated Platform
/// Admin never destroys incident history.
model SecurityIncident {
  id String @id @default(uuid())

  /// Deterministic dedupe key derived from sourceRule + scope + affected
  /// resource (see securitySignalService.ts buildIncidentKey). Unique at the
  /// DB level so concurrent identical signals can only ever upsert the SAME
  /// row — never a race-prone find-then-create.
  incidentKey String @unique

  organizationId String?
  clinicId       String?

  category String // auth_brute_force | cross_tenant_access | export_anomaly | webhook_signature
  severity String // low | medium | high | critical
  status   String @default("open") // open | acknowledged | investigating | contained | resolved | closed | false_positive

  title   String
  summary String

  firstDetectedAt DateTime
  lastDetectedAt  DateTime
  occurrenceCount Int      @default(1)

  sourceType String // e.g. "auth_login", "clinic_scope_denial", "clinic_bulk_export"
  sourceRule String // stable rule key, e.g. "auth.brute_force.v1"

  affectedResourceType String?
  affectedResourceId   String?

  assignedToPlatformAdminId String?
  assignedToPlatformAdmin   PlatformAdmin? @relation("SecurityIncidentAssignee", fields: [assignedToPlatformAdminId], references: [id], onDelete: SetNull)

  acknowledgedAt                DateTime?
  acknowledgedByPlatformAdminId String?
  acknowledgedByPlatformAdmin   PlatformAdmin? @relation("SecurityIncidentAcknowledger", fields: [acknowledgedByPlatformAdminId], references: [id], onDelete: SetNull)

  containedAt                DateTime?
  containedByPlatformAdminId String?
  containedByPlatformAdmin   PlatformAdmin? @relation("SecurityIncidentContainer", fields: [containedByPlatformAdminId], references: [id], onDelete: SetNull)

  resolvedAt                DateTime?
  resolvedByPlatformAdminId String?
  resolvedByPlatformAdmin   PlatformAdmin? @relation("SecurityIncidentResolver", fields: [resolvedByPlatformAdminId], references: [id], onDelete: SetNull)

  closedAt                DateTime?
  closedByPlatformAdminId String?
  closedByPlatformAdmin   PlatformAdmin? @relation("SecurityIncidentCloser", fields: [closedByPlatformAdminId], references: [id], onDelete: SetNull)

  resolutionSummary  String?
  containmentSummary String?

  /// Technical placeholder only, default true. Never flipped by any
  /// automated detection code — only ever changed via an explicit Platform
  /// Admin action (recorded in SecurityIncidentActivity), and even then this
  /// is not a legal determination.
  legalReviewRequired Boolean @default(true)
  legalReviewStatus   String  @default("pending") // pending | in_review | not_required | advised

  /// Safe, sanitized metadata only — same allowlist as SecuritySignalEvent.
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activity SecurityIncidentActivity[]

  @@index([status, severity, lastDetectedAt])
  @@index([organizationId, status])
  @@index([clinicId, status])
  @@index([category, lastDetectedAt])
  @@index([assignedToPlatformAdminId, status])
}

/// Immutable incident lifecycle history — only ever created, never updated
/// or deleted, and always inserted in the same DB transaction as the
/// SecurityIncident row it documents. Never contains secrets or patient
/// content — same allowlist/sanitizer as SecuritySignalEvent.
model SecurityIncidentActivity {
  id         String           @id @default(uuid())
  incidentId String
  incident   SecurityIncident @relation(fields: [incidentId], references: [id])

  action         String // created | occurrence_recorded | severity_escalated | acknowledged | investigating | assigned | contained | resolved | closed | false_positive | reopened | note_added
  previousStatus String?
  newStatus      String?

  actorPlatformAdminId String?
  actorPlatformAdmin   PlatformAdmin? @relation("SecurityIncidentActivityActor", fields: [actorPlatformAdminId], references: [id], onDelete: SetNull)

  note     String?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([incidentId, createdAt])
}
