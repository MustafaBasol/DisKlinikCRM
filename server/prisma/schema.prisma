  entityId             String // Legacy or general fallback
  patientId            String?
  appointmentId        String?
  treatmentCaseId      String?
  insuranceProvisionId String?
  action               String
  description          String?
  metadataJson         String?
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime @default(now())

  patient            Patient?            @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointment        Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  treatmentCase      TreatmentCase?      @relation(fields: [treatmentCaseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  insuranceProvision InsuranceProvision? @relation(fields: [insuranceProvisionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Setting {
  id        String   @id @default(uuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, key])
}

model ClinicRecallSetting {
  id                                     String   @id @default(uuid())
  clinicId                               String   @unique
  clinic                                 Clinic   @relation(fields: [clinicId], references: [id])
  isEnabled                              Boolean  @default(false)
  defaultActionMode                      String   @default("LIST_ONLY") // LIST_ONLY | CREATE_TASK | CREATE_MESSAGE_DRAFT | AUTO_SEND_WHATSAPP
  checkupEnabled                         Boolean  @default(true)
  checkupAfterDays                       Int      @default(180)
  checkupSendTiming                      String   @default("MANUAL") // SAME_DAY | NEXT_DAY | MANUAL
  checkupSendTime                        String   @default("10:00")
  checkupActionMode                      String   @default("LIST_ONLY")
  checkupMessageTemplateId               String?
  treatmentPlanFollowupEnabled           Boolean  @default(true)
  treatmentPlanFollowupAfterDays         Int      @default(7)
  treatmentPlanFollowupRepeatDays        Int      @default(14)
  treatmentPlanFollowupMaxAttempts       Int      @default(3)
  treatmentPlanFollowupActionMode        String   @default("CREATE_TASK")
  treatmentPlanFollowupMessageTemplateId String?
  incompleteTreatmentEnabled             Boolean  @default(true)
  incompleteTreatmentAfterDays           Int      @default(14)
  incompleteTreatmentActionMode          String   @default("CREATE_TASK")
  incompleteTreatmentMessageTemplateId   String?
  incompleteTreatmentAutoCreateTask      Boolean  @default(true)
  noShowFollowupEnabled                  Boolean  @default(true)
  noShowFollowupAfterHours               Int      @default(24)
  noShowFollowupActionMode               String   @default("CREATE_TASK")
  noShowFollowupMessageTemplateId        String?
  noShowFollowupAutoCreateTask           Boolean  @default(true)
  paymentFollowupEnabled                 Boolean  @default(true)
  paymentFollowupAfterDays               Int      @default(3)
  paymentFollowupActionMode              String   @default("CREATE_TASK")
  paymentFollowupMessageTemplateId       String?
  respectCommunicationConsent            Boolean  @default(true)
  createdAt                              DateTime @default(now())
  updatedAt                              DateTime @updatedAt

  @@index([clinicId])
}

model RecallCandidate {
  id                       String                  @id @default(uuid())
  clinicId                 String
  clinic                   Clinic                  @relation(fields: [clinicId], references: [id])
  patientId                String
  patient                  Patient                 @relation(fields: [patientId], references: [id])
  recallType               String
  priority                 String                  @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  status                   String                  @default("PENDING") // PENDING | TASK_CREATED | MESSAGE_DRAFTED | CONTACTED | APPOINTMENT_BOOKED | DECLINED | SNOOZED | COMPLETED | CANCELLED
  sourceType               String
  sourceId                 String
  treatmentCaseId          String?
  treatmentCase            TreatmentCase?          @relation(fields: [treatmentCaseId], references: [id])
  treatmentPlanProcedureId String?
  treatmentPlanProcedure   TreatmentPlanProcedure? @relation(fields: [treatmentPlanProcedureId], references: [id])
  appointmentId            String?
  appointment              Appointment?            @relation(fields: [appointmentId], references: [id])
  paymentId                String?
  payment                  Payment?                @relation(fields: [paymentId], references: [id])
  estimatedValue           Float?
  dueAt                    DateTime
  lastContactedAt          DateTime?
  nextActionAt             DateTime?
  attemptsCount            Int                     @default(0)
  maxAttempts              Int                     @default(3)
  assignedToId             String?
  assignedTo               User?                   @relation("RecallCandidateAssignee", fields: [assignedToId], references: [id])
  messageTemplateId        String?
  messageTemplate          MessageTemplate?        @relation(fields: [messageTemplateId], references: [id])
  lastMessageDraft         String?
  note                     String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  completedAt              DateTime?
  cancelledAt              DateTime?

  actions RecallAction[]

  @@index([clinicId, status, dueAt])
  @@index([clinicId, recallType, status])
  @@index([clinicId, patientId])
  @@index([clinicId, sourceType, sourceId])
  @@index([assignedToId])
}

model RecallAction {
  id            String          @id @default(uuid())
  clinicId      String
  clinic        Clinic          @relation(fields: [clinicId], references: [id])
  candidateId   String
  candidate     RecallCandidate @relation(fields: [candidateId], references: [id])
