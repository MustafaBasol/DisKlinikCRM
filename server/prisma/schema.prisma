// ── Stok / Malzeme Takibi ────────────────────────────────────────────────────

model InventoryItem {
  id             String       @id @default(uuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id])
  name           String
  // implant | prosthetic | consumable | medication | equipment | other
  category       String       @default("consumable")
  unit           String       @default("piece") // piece | box | ml | gram | vial | set
  currentStock   Float        @default(0)
  minimumStock   Float        @default(0) // triggers low-stock alert
  unitCost       Float?
  supplier       String?
  barcode        String?
  notes          String?
  isActive       Boolean      @default(true)
  organizationId String // Phase 1b: NOT NULL after backfill
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  transactions              InventoryTransaction[]
  appointmentTypeMaterials  AppointmentTypeMaterial[]
  treatmentPackageMaterials TreatmentPackageMaterial[]

  @@index([clinicId, category, isActive])
}

model InventoryTransaction {
  id                       String                       @id @default(uuid())
  clinicId                 String
  clinic                   Clinic                       @relation(fields: [clinicId], references: [id])
  itemId                   String
  item                     InventoryItem                @relation(fields: [itemId], references: [id])
  // in | out | adjustment
  type                     String
  quantity                 Float
  unitCost                 Float?
  // purchase | usage | treatment_use | adjustment | wastage | return
  reason                   String?
  treatmentCaseId          String?
  treatmentCase            TreatmentCase?               @relation(fields: [treatmentCaseId], references: [id])
  treatmentPlanProcedureId String?
  treatmentPlanProcedure   TreatmentPlanProcedure?      @relation(fields: [treatmentPlanProcedureId], references: [id])
  serviceId                String?
  service                  AppointmentType?             @relation("InventoryTransactionService", fields: [serviceId], references: [id])
  treatmentPackageId       String?
  treatmentPackage         TreatmentPackage?            @relation(fields: [treatmentPackageId], references: [id])
  packageApplicationId     String?
  packageApplication       TreatmentPackageApplication? @relation(fields: [packageApplicationId], references: [id])
  performedById            String
  performedBy              User                         @relation("InventoryPerformedBy", fields: [performedById], references: [id])
  notes                    String?
  createdAt                DateTime                     @default(now())

  @@index([clinicId, itemId, createdAt])
  @@index([clinicId, treatmentPlanProcedureId])
  @@index([clinicId, packageApplicationId])
}

// ── Tedavi Planı Görselleştirme ───────────────────────────────────────────────

model TreatmentPlanProcedure {
  id                   String                       @id @default(uuid())
  clinicId             String
  clinic               Clinic                       @relation(fields: [clinicId], references: [id])
  treatmentCaseId      String
  treatmentCase        TreatmentCase                @relation(fields: [treatmentCaseId], references: [id])
  patientId            String
  patient              Patient                      @relation(fields: [patientId], references: [id])
  toothFdi             Int? // FDI notation; null = procedure not tooth-specific
  procedureName        String
  serviceId            String?
  service              AppointmentType?             @relation(fields: [serviceId], references: [id])
  packageApplicationId String?
  packageApplication   TreatmentPackageApplication? @relation(fields: [packageApplicationId], references: [id])
  treatmentPackageId   String?
  treatmentPackage     TreatmentPackage?            @relation(fields: [treatmentPackageId], references: [id])
  packageItemId        String?
  packageItem          TreatmentPackageItem?        @relation(fields: [packageItemId], references: [id])
  // planned | in_progress | completed | cancelled
  status               String                       @default("planned")
  notes                String?
  estimatedCost        Float?
  scheduledDate        DateTime?
  completedAt          DateTime?
  stockDeductedAt      DateTime?
  stockDeductionStatus String?
  stockDeductionError  String?
  createdById          String
  createdBy            User                         @relation("ProcedureCreator", fields: [createdById], references: [id])
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  inventoryTransactions InventoryTransaction[]
  recallCandidates      RecallCandidate[]

  @@index([clinicId, treatmentCaseId])
  @@index([clinicId, patientId, toothFdi])
  @@index([clinicId, packageApplicationId])
  @@index([clinicId, treatmentPackageId])
}

// ── Kalıcı Bildirimler ────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id])
