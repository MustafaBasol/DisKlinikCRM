// ── Provider-Agnostic WhatsApp Infrastructure ─────────────────────────────────

/// Organization-level WhatsApp connection. One connection can be shared by multiple branches.
model WhatsAppConnection {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  // evolution_api | meta_cloud_api
  provider       String       @default("evolution_api")
  // disconnected | connecting | connected | error
  status         String       @default("disconnected")
  phoneNumber    String?
  displayName    String?

  // Evolution API fields
  evolutionApiUrl          String?
  evolutionInstanceName    String? @unique
  // Encrypted at rest with AES-256-GCM (utils/encryption.ts encryptSecret)
  evolutionApiKeyEncrypted String?

  // Meta Cloud API foundation fields
  metaBusinessId           String?
  metaWabaId               String?
  metaPhoneNumberId        String?   @unique
  metaAppId                String?
  // Encrypted at rest with AES-256-GCM (utils/encryption.ts encryptSecret)
  metaAccessTokenEncrypted String?
  metaWebhookVerifyToken   String?
  // Encrypted at rest with enc:v1: prefix (utils/encryption.ts encryptSecretTagged);
  // legacy plaintext rows are still readable until re-saved
  metaWebhookSecret        String?
  // Token lifecycle tracking — Meta tokens expire ~60 days unless refreshed
  // valid | expiring | expired | unknown
  metaTokenStatus          String?   @default("unknown")
  metaTokenExpiresAt       DateTime?
  metaTokenLastCheckedAt   DateTime?

  // Shared webhook secret for this connection — encrypted at rest (enc:v1: prefix)
  webhookSecret   String?
  lastConnectedAt DateTime?
  lastError       String?
  isActive        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinics       ClinicWhatsAppConnection[]
  sentMessages  SentMessage[]
  inboxEntries  WhatsAppInboxEntry[]
  metaTemplates MessageTemplate[]          @relation("MessageTemplateMetaConnection")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([provider])
}

/// Maps one WhatsAppConnection to one Clinic. Supports shared (one connection → many clinics)
/// and dedicated (one connection → one clinic) topology.
model ClinicWhatsAppConnection {
  id                   String             @id @default(uuid())
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id])
  clinicId             String
  clinic               Clinic             @relation(fields: [clinicId], references: [id])
  whatsappConnectionId String
  whatsappConnection   WhatsAppConnection @relation(fields: [whatsappConnectionId], references: [id])
  isDefault            Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([clinicId, whatsappConnectionId])
  @@index([organizationId])
  @@index([clinicId])
  @@index([whatsappConnectionId])
}

/// Incoming WhatsApp messages that could not be automatically assigned to a clinic.
/// Priority A-C resolution routes to existing flow; Priority D creates one of these.
/// After staff resolution: clinicId is set, needsClinicResolution=false, status=resolved.
model WhatsAppInboxEntry {
  id                    String              @id @default(uuid())
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id])
  whatsappConnectionId  String?
  whatsappConnection    WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id])
  clinicId              String? // null = unresolved
  clinic                Clinic?             @relation("InboxEntryClinic", fields: [clinicId], references: [id])
  patientId             String? // null = no matched patient yet
  patient               Patient?            @relation("InboxEntryPatient", fields: [patientId], references: [id])
  resolvedByUserId      String?
  resolvedBy            User?               @relation("InboxEntryResolver", fields: [resolvedByUserId], references: [id])
  phone                 String
  displayName           String?
  lastMessageText       String?
  messageCount          Int                 @default(1)
  externalMessageId     String?
  rawPayload            Json?
  needsClinicResolution Boolean             @default(false)
  // open | resolved
  status                String              @default("open")
  resolvedAt            DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([organizationId, needsClinicResolution])
  @@index([organizationId, status])
  @@index([organizationId, clinicId])
  @@index([whatsappConnectionId, phone])
}

// ── Sprint 13: Operational Monitoring ────────────────────────────────────────

/// Immutable audit trail of important admin/system actions.
/// Separate from ActivityLog (clinic-scoped, FK-heavy) — AuditLog is org-scoped
/// and designed for compliance, security reviews and operational investigations.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  clinicId       String?
  actorUserId    String?
  actorRole      String?
  action         String // user_login | branch_created | payment_created | ...
  entityType     String // user | branch | appointment | payment | whatsapp_connection | ...
  entityId       String?
  description    String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([clinicId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

/// System-level operational events: integration failures, webhook errors, etc.
/// Separate from AuditLog — these are monitorable / resolvable events.
model OperationalEvent {
  id             String    @id @default(uuid())
  organizationId String
  clinicId       String?
  // info | warning | error | critical
  severity       String    @default("info")
  // whatsapp | appointment | finance | auth | system
  source         String
  message        String
  metadata       Json?
  resolvedAt     DateTime?
  resolvedById   String?
  createdAt      DateTime  @default(now())

  /// Optional deterministic dedupe key (e.g. "clinic-bulk-export:<jobId>:export_requested").
  /// Left null by every feature that doesn't need dedupe. When set, a create is performed
  /// as an upsert on this unique key so duplicate-alert suppression is atomic (never
  /// check-then-insert) — see clinicBulkExportPackage.ts.
  dedupeKey      String?   @unique

  @@index([organizationId, severity])
  @@index([organizationId, source])
  @@index([organizationId, resolvedAt])
  @@index([createdAt])
}

// ── Sprint 23: Instagram DM Integration ──────────────────────────────────────

/// Shared inbound message idempotency ledger for all messaging channels.
/// connectionId is intentionally provider-agnostic: it can reference WhatsAppConnection,
/// InstagramConnection, or a future channel-specific connection model.
model MessagingInboundEvent {
  id                     String    @id @default(uuid())
  channel                String
  provider               String
  connectionId           String?
  clinicId               String?
  organizationId         String?
  providerMessageId      String
  providerConversationId String?
  fromExternalId         String?
  toExternalId           String?
  fromPhone              String?
  toPhone                String?
  eventType              String    @default("message")
  direction              String    @default("inbound")
  status                 String    @default("received")
  /// Retry job'un kaç kez yeniden işlemeyi denediği (docs/45 Faz 2 #6)
  attempts               Int       @default(0)
  rawPayload             Json?
  errorMessage           String?
  processedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([channel, provider, connectionId, providerMessageId])
  @@index([organizationId, status, createdAt])
  @@index([clinicId, status, createdAt])
  @@index([channel, provider, providerMessageId])
  @@index([status, updatedAt])
}

/// Cron job'lar için paylaşımlı lease kilidi (docs/45 Faz 3 #9-10).
