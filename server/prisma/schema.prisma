generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id              String   @id @default(uuid())
  name            String
  legalName       String?
  address         String?
  phone           String?
  email           String?
  website         String?
  timezone        String   @default("UTC")
  currency        String   @default("USD")
  defaultLanguage String   @default("en")
  slug            String   // Phase 1b: NOT NULL — @@unique([organizationId, slug]) added below
  status          String   @default("trial") // trial | active | suspended | cancelled
  trialEndsAt     DateTime?
  maxUsers        Int      @default(10)  // Kept for backwards compat; plan limits read from Organization after migration
  maxPatients     Int      @default(500) // Kept for backwards compat
  planId          String?               // Staged migration: kept until Organization.planId is validated
  plan            Plan?    @relation(fields: [planId], references: [id])
  organizationId  String                // Phase 1b: NOT NULL after backfill
  organization    Organization          @relation(fields: [organizationId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users                User[]
  doctorAvailabilities DoctorAvailability[]
  doctorOffDays        DoctorOffDay[]
  patients             Patient[]
  appointmentTypes     AppointmentType[]
  appointments         Appointment[]
  appointmentRequests  AppointmentRequest[]
  treatmentCases       TreatmentCase[]
  tasks                Task[]
  payments             Payment[]
  insuranceProvisions  InsuranceProvision[]
  messageTemplates     MessageTemplate[]
  sentMessages         SentMessage[]
  activityLogs         ActivityLog[]
  whatsappConversationStates WhatsAppConversationState[]
  whatsappConversationMessages WhatsAppConversationMessage[]
  settings             Setting[]
  patientAttachments   PatientAttachment[]
  toothRecords         ToothRecord[]
  paymentPlans         PaymentPlan[]
  practitionerCompRules    PractitionerCompensationRule[]
  serviceCompRules         ServiceCompensationRule[]
  practitionerEarnings     PractitionerEarning[]
  practitionerPayouts      PractitionerPayout[]
  inventoryItems           InventoryItem[]
  inventoryTransactions    InventoryTransaction[]
  treatmentPlanProcedures  TreatmentPlanProcedure[]
  notifications            Notification[]
  invitations              ClinicInvitation[]
  defaultUsers             User[]            @relation("UserDefaultClinic")
  primaryPatients          Patient[]         @relation("PatientPrimaryClinic")
  userClinics              UserClinic[]
  patientClinics           PatientClinic[]
  clinicWorkingHours       ClinicWorkingHours[]
  clinicWhatsAppConnections ClinicWhatsAppConnection[]
  whatsappInboxEntries  WhatsAppInboxEntry[] @relation("InboxEntryClinic")
  clinicInstagramConnections ClinicInstagramConnection[]
  instagramInboxEntries InstagramInboxEntry[] @relation("InstagramInboxEntryClinic")

  @@unique([organizationId, slug])
}

model User {
  id           String    @id @default(uuid())
  clinicId     String
  clinic       Clinic    @relation(fields: [clinicId], references: [id])
  firstName    String
  lastName     String
  email        String
  phone        String?
  role         String // OWNER | ORG_ADMIN | CLINIC_MANAGER | DENTIST | RECEPTIONIST | BILLING | ASSISTANT
  passwordHash String
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  commissionRate Float     @default(0)
  organizationId      String                // Phase 1b: NOT NULL after backfill
  organization        Organization          @relation(fields: [organizationId], references: [id])
  defaultClinicId     String?               // UI default only — NOT used for authorization
  defaultClinic       Clinic?               @relation("UserDefaultClinic", fields: [defaultClinicId], references: [id])
  canAccessAllClinics Boolean               @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tasksCreated        Task[]               @relation("TaskCreator")
  tasksAssigned       Task[]               @relation("TaskAssignee")
  appointments        Appointment[]        @relation("Practitioner")
  appointmentRequests AppointmentRequest[] @relation("AppointmentRequestPractitioner")
  availabilities      DoctorAvailability[] @relation("DoctorAvailability")
  offDays             DoctorOffDay[]       @relation("DoctorOffDays")
  treatmentCases      TreatmentCase[]      @relation("Practitioner")
  insuranceAssigned   InsuranceProvision[] @relation("InsuranceAssignedTo")
  insuranceCreated    InsuranceProvision[] @relation("InsuranceCreatedBy")
  sentMessages        SentMessage[]
  createdTemplates    MessageTemplate[]    @relation("TemplateCreator")
  activityLogs        ActivityLog[]
  uploadedAttachments PatientAttachment[]  @relation("AttachmentUploader")
  toothRecordsCreated  ToothRecord[]        @relation("ToothRecordCreator")
  paymentPlans         PaymentPlan[]
  compensationRules    PractitionerCompensationRule[] @relation("PractitionerCompRules")
  serviceCompRules     ServiceCompensationRule[]      @relation("ServiceCompRules")
  practitionerEarnings PractitionerEarning[]          @relation("PractitionerEarnings")
  practitionerPayouts  PractitionerPayout[]           @relation("PractitionerPayouts")
  payoutsCreated       PractitionerPayout[]           @relation("PayoutCreator")
  inventoryTransactions InventoryTransaction[]        @relation("InventoryPerformedBy")
  proceduresCreated     TreatmentPlanProcedure[]      @relation("ProcedureCreator")
  userClinics           UserClinic[]
  resolvedInboxEntries  WhatsAppInboxEntry[] @relation("InboxEntryResolver")
  resolvedInstagramEntries InstagramInboxEntry[] @relation("InstagramInboxEntryResolver")

  // Phase 1b: changed to organizationId scope for multi-branch
  @@unique([organizationId, email])
}

model DoctorAvailability {
  id             String   @id @default(uuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User     @relation("DoctorAvailability", fields: [practitionerId], references: [id])
  weekday        Int // 0 Sunday, 1 Monday, ... 6 Saturday
  startTime      String // HH:mm
  endTime        String // HH:mm
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clinicId, practitionerId, weekday])
}

model DoctorOffDay {
  id             String   @id @default(uuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User     @relation("DoctorOffDays", fields: [practitionerId], references: [id])
  date           String   // YYYY-MM-DD (clinic local date)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clinicId, practitionerId, date])
  @@index([clinicId, practitionerId])
}

model Patient {
  id                   String    @id @default(uuid())
  clinicId             String
  clinic               Clinic    @relation(fields: [clinicId], references: [id])
  firstName            String
  lastName             String
  email                String?
  phone                String?
  dateOfBirth          DateTime?
  address              String?
  city                 String?
  postalCode           String?
  country              String?
  patientStatus        String    @default("new") // new, active, inactive, archived
  source               String? // google, referral, social_media, etc.
  notes                String?
  communicationConsent Boolean   @default(false)
  marketingConsent     Boolean   @default(false)
  organizationId       String                // Phase 1b: NOT NULL after backfill
  organization         Organization          @relation(fields: [organizationId], references: [id])
  primaryClinicId      String?               // Default/preferred branch (not exclusive)
  primaryClinic        Clinic?               @relation("PatientPrimaryClinic", fields: [primaryClinicId], references: [id])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  appointments        Appointment[]
  appointmentRequests AppointmentRequest[]
  treatmentCases      TreatmentCase[]
  tasks               Task[]
  payments            Payment[]
  insuranceProvisions InsuranceProvision[]
  sentMessages        SentMessage[]
  activityLogs        ActivityLog[]
  whatsappConversationMessages WhatsAppConversationMessage[]
  attachments         PatientAttachment[]
  toothRecords        ToothRecord[]
  paymentPlans        PaymentPlan[]
  practitionerEarnings PractitionerEarning[]
  treatmentPlanProcedures TreatmentPlanProcedure[]
  patientClinics          PatientClinic[]
  whatsappInboxEntries    WhatsAppInboxEntry[] @relation("InboxEntryPatient")
  instagramInboxEntries   InstagramInboxEntry[] @relation("InstagramInboxEntryPatient")
}

model AppointmentType {
  id              String   @id @default(uuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  name            String
  durationMinutes Int
  color           String?
  isActive        Boolean  @default(true)
  category        String?
  description     String?
  basePrice       Float?
  currency        String?
  isService       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments         Appointment[]
  appointmentRequests  AppointmentRequest[]
  treatmentCases       TreatmentCase[]
  serviceCompRules     ServiceCompensationRule[] @relation("ServiceCompRules")
  practitionerEarnings PractitionerEarning[]     @relation("EarningService")
  treatmentPlanProcedures TreatmentPlanProcedure[]
}

model Appointment {
  id                 String          @id @default(uuid())
  clinicId           String
  clinic             Clinic          @relation(fields: [clinicId], references: [id])
  patientId          String
  patient            Patient         @relation(fields: [patientId], references: [id])
  practitionerId     String
  practitioner       User            @relation("Practitioner", fields: [practitionerId], references: [id])
  appointmentTypeId  String
  appointmentType    AppointmentType @relation(fields: [appointmentTypeId], references: [id])
  title              String?
  startTime          DateTime
  endTime            DateTime
  status             String          @default("scheduled") // scheduled, confirmed, completed, cancelled, no_show, etc.
  notes              String?
  cancellationReason String?
  noShowReason       String?
  // No-show recovery fields (Sprint 18)
  noShowMarkedAt     DateTime?
  noShowMarkedById   String?
  recoveryStatus     String?         // unresolved | contacted | recovered
  recoveryNote       String?
  recoveredAt        DateTime?
  recoveredById      String?
  createdById        String?
  updatedById        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])

  tasks          Task[]
  sentMessages   SentMessage[]
  activityLogs   ActivityLog[]
  sourceRequests AppointmentRequest[] @relation("ConvertedAppointment")
}

model AppointmentRequest {
  id                     String           @id @default(uuid())
  clinicId               String
  clinic                 Clinic           @relation(fields: [clinicId], references: [id])
  patientId              String?
  patient                Patient?         @relation(fields: [patientId], references: [id])
  patientName            String
  phone                  String
  email                  String?
  appointmentTypeId      String?
  appointmentType        AppointmentType? @relation(fields: [appointmentTypeId], references: [id])
  practitionerId         String?
  practitioner           User?            @relation("AppointmentRequestPractitioner", fields: [practitionerId], references: [id])
  preferredStartTime     DateTime?
  preferredEndTime       DateTime?
  requestType            String           @default("appointment") // appointment, reschedule, cancel, info
  source                 String           @default("whatsapp")
  status                 String           @default("pending") // pending, approved, rejected, converted, closed
  rawMessage             String?
  notes                  String?
  rejectionReason        String?
  convertedAppointmentId String?
  convertedAppointment   Appointment?     @relation("ConvertedAppointment", fields: [convertedAppointmentId], references: [id])
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@index([clinicId, status, createdAt])
  @@index([clinicId, phone])
  @@index([clinicId, practitionerId])
}

model WhatsAppConversationState {
  id                          String   @id @default(uuid())
  clinicId                    String
  clinic                      Clinic   @relation(fields: [clinicId], references: [id])
  phone                       String
  lastProviderMessageId       String?
  customerName                String?
  currentIntent               String?
  step                        String?
  selectedAppointmentTypeId   String?
  selectedAppointmentTypeName String?
  selectedPractitionerId      String?
  selectedDate                String?
  selectedTime                String?
  lastMessage                 String?
  stateJson                   Json?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([clinicId, phone])
  @@index([clinicId, updatedAt])
}

model WhatsAppConversationMessage {
  id                String   @id @default(uuid())
  clinicId          String
  clinic            Clinic   @relation(fields: [clinicId], references: [id])
  patientId         String
  patient           Patient  @relation(fields: [patientId], references: [id])
  phone             String
  providerMessageId String?
  direction         String
  text              String
  rawPayload        Json?
  createdAt         DateTime @default(now())

  @@unique([clinicId, providerMessageId])
  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, phone, createdAt])
}

model TreatmentCase {
  id                String           @id @default(uuid())
  clinicId          String
  clinic            Clinic           @relation(fields: [clinicId], references: [id])
  patientId         String
  patient           Patient          @relation(fields: [patientId], references: [id])
  practitionerId    String?
  practitioner      User?            @relation("Practitioner", fields: [practitionerId], references: [id])
  appointmentTypeId String?
  appointmentType   AppointmentType? @relation(fields: [appointmentTypeId], references: [id])
  title             String
  description       String?
  stage             String           @default("new") // new, quote_sent, in_progress, completed, lost
  estimatedAmount   Float?
  acceptedAmount    Float?
  currency          String?
  expectedStartDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  createdById       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  tasks               Task[]
  appointments        Appointment[]
  payments            Payment[]
  insuranceProvisions InsuranceProvision[]
  sentMessages        SentMessage[]
  activityLogs        ActivityLog[]
  paymentPlans        PaymentPlan[]
  practitionerEarnings PractitionerEarning[]
  inventoryTransactions InventoryTransaction[]
  procedures          TreatmentPlanProcedure[]
}

model InsuranceProvision {
  id                          String         @id @default(uuid())
  clinicId                    String
  clinic                      Clinic         @relation(fields: [clinicId], references: [id])
  patientId                   String
  patient                     Patient        @relation(fields: [patientId], references: [id])
  treatmentCaseId             String?
  treatmentCase               TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  insuranceProviderName       String
  insuranceType               String
  policyNumber                String?
  provisionNumber             String?
  status                      String         @default("draft")
  requestedAmount             Float
  approvedAmount              Float?
  patientResponsibilityAmount Float?
  currency                    String         @default("TRY")
  submittedAt                 DateTime?
  respondedAt                 DateTime?
  rejectionReason             String?
  notes                       String?
  assignedToId                String?
  assignedTo                  User?          @relation("InsuranceAssignedTo", fields: [assignedToId], references: [id])
  createdById                 String
  createdBy                   User           @relation("InsuranceCreatedBy", fields: [createdById], references: [id])
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  activityLogs ActivityLog[]
}

model Task {
  id              String         @id @default(uuid())
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  patientId       String?
  patient         Patient?       @relation(fields: [patientId], references: [id])
  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  appointmentId   String?
  appointment     Appointment?   @relation(fields: [appointmentId], references: [id])
  assignedToId    String?
  assignedTo      User?          @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User           @relation("TaskCreator", fields: [createdById], references: [id])
  title           String
  description     String?
  dueDate         DateTime?
  status          String         @default("open") // open, in_progress, completed, cancelled
  priority        String         @default("normal") // low, normal, high, urgent
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Payment {
  id              String         @id @default(uuid())
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  amount          Float
  currency        String
  paymentMethod   String // cash, card, bank_transfer, etc.
  paymentStatus   String         @default("pending") // pending, partial, paid, refunded, cancelled
  paidAt          DateTime?
  notes           String?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sentMessages         SentMessage[]
  installment          PaymentPlanInstallment?
  practitionerEarnings PractitionerEarning[]
}

model MessageTemplate {
  id        String   @id @default(uuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  name      String
  channel   String // sms, whatsapp, email
  subject   String?
  body      String
  language  String   @default("en")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation("TemplateCreator", fields: [createdById], references: [id])

  sentMessages SentMessage[]
}

model SentMessage {
  id                String           @id @default(uuid())
  clinicId          String
  clinic            Clinic           @relation(fields: [clinicId], references: [id])
  patientId         String
  patient           Patient          @relation(fields: [patientId], references: [id])
  appointmentId     String?
  appointment       Appointment?     @relation(fields: [appointmentId], references: [id])
  treatmentCaseId   String?
  treatmentCase     TreatmentCase?   @relation(fields: [treatmentCaseId], references: [id])
  paymentId         String?
  payment           Payment?         @relation(fields: [paymentId], references: [id])
  templateId        String?
  template          MessageTemplate? @relation(fields: [templateId], references: [id])
  channel           String
  recipient         String
  subject           String?
  body              String
  status            String           @default("prepared") // prepared, sent, failed, delivered, read
  providerMessageId     String?
  sentAt                DateTime?
  createdById           String?
  createdBy             User?            @relation(fields: [createdById], references: [id])
  // Provider-agnostic WhatsApp extension fields
  organizationId        String?
  organization          Organization?    @relation(fields: [organizationId], references: [id])
  whatsappConnectionId  String?
  whatsappConnection    WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id])
  provider              String?          // evolution_api | meta_cloud_api
  direction             String?          // outgoing | incoming
  externalMessageId     String?          // Provider message ID for tracking
  createdAt             DateTime         @default(now())
}

model ActivityLog {
  id                   String   @id @default(uuid())
  clinicId             String
  clinic               Clinic   @relation(fields: [clinicId], references: [id])
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  entityType           String
  entityId             String // Legacy or general fallback
  patientId            String?
  appointmentId        String?
  treatmentCaseId      String?
  insuranceProvisionId String?
  action               String
  description          String?
  metadataJson         String?
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime @default(now())

  patient            Patient?            @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointment        Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  treatmentCase      TreatmentCase?      @relation(fields: [treatmentCaseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  insuranceProvision InsuranceProvision? @relation(fields: [insuranceProvisionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Setting {
  id        String   @id @default(uuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, key])
}

model PatientAttachment {
  id           String   @id @default(uuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  fileName     String
  originalName String
  fileSize     Int
  mimeType     String
  filePath     String
  uploadedById String
  uploadedBy   User     @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
}

model ToothRecord {
  id          String   @id @default(uuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  toothFdi    Int      // FDI notation: 11-18, 21-28, 31-38, 41-48
  status      String   // planned, treated, issue, missing, crown, implant
  note        String?
  createdById String
  createdBy   User     @relation("ToothRecordCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([patientId, toothFdi])
  @@index([clinicId, patientId])
}

model PaymentPlan {
  id              String    @id @default(uuid())
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  totalAmount     Float
  currency        String    @default("TRY")
  installmentCount Int
  description     String?
  status          String    @default("active") // active, completed, cancelled
  createdById     String?
  createdBy       User?     @relation(fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  installments    PaymentPlanInstallment[]

  @@index([clinicId, patientId])
  @@index([clinicId, status])
}

model PaymentPlanInstallment {
  id            String      @id @default(uuid())
  planId        String
  plan          PaymentPlan @relation(fields: [planId], references: [id])
  installmentNo Int
  dueDate       DateTime
  amount        Float
  status        String      @default("pending") // pending, paid, overdue
  paymentId     String?     @unique
  payment       Payment?    @relation(fields: [paymentId], references: [id])
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([planId])
  @@index([dueDate, status])
}

// ─── Practitioner Earnings ──────────────────────────────────────────────────

model PractitionerCompensationRule {
  id                 String   @id @default(uuid())
  clinicId           String
  clinic             Clinic   @relation(fields: [clinicId], references: [id])
  practitionerId     String
  practitioner       User     @relation("PractitionerCompRules", fields: [practitionerId], references: [id])
  compensationType   String   @default("percentage") // fixed | percentage | fixed_plus_percentage | per_service
  fixedMonthlyAmount Float?
  defaultPercentage  Float?
  calculationBase    String   @default("collected") // billed | collected
  startDate          DateTime?
  endDate            DateTime?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([clinicId, practitionerId, isActive])
}

model ServiceCompensationRule {
  id             String          @id @default(uuid())
  clinicId       String
  clinic         Clinic          @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User            @relation("ServiceCompRules", fields: [practitionerId], references: [id])
  serviceId      String
  service        AppointmentType @relation("ServiceCompRules", fields: [serviceId], references: [id])
  percentage     Float?
  fixedAmount    Float?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([practitionerId, serviceId])
  @@index([clinicId, practitionerId, isActive])
}

model PractitionerEarning {
  id                    String              @id @default(uuid())
  clinicId              String
  clinic                Clinic              @relation(fields: [clinicId], references: [id])
  practitionerId        String
  practitioner          User                @relation("PractitionerEarnings", fields: [practitionerId], references: [id])
  patientId             String?
  patient               Patient?            @relation(fields: [patientId], references: [id])
  treatmentCaseId       String?
  treatmentCase         TreatmentCase?      @relation(fields: [treatmentCaseId], references: [id])
  paymentId             String?
  payment               Payment?            @relation(fields: [paymentId], references: [id])
  serviceId             String?
  service               AppointmentType?    @relation("EarningService", fields: [serviceId], references: [id])
  grossAmount           Float
  collectedAmount       Float               @default(0)
  earningAmount         Float
  calculationBase       String              // billed | collected
  percentageApplied     Float?
  fixedAmountApplied    Float?
  status                String              @default("pending") // pending | approved | paid | cancelled
  periodMonth           Int
  periodYear            Int
  adminAdjustmentAmount Float?
  adminAdjustmentReason String?
  approvedAt            DateTime?
  approvedById          String?
  payoutId              String?
  payout                PractitionerPayout? @relation(fields: [payoutId], references: [id])
  paidAt                DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([clinicId, practitionerId, periodYear, periodMonth])
  @@index([clinicId, status])
}

model PractitionerPayout {
  id             String    @id @default(uuid())
  clinicId       String
  clinic         Clinic    @relation(fields: [clinicId], references: [id])
  practitionerId String
  practitioner   User      @relation("PractitionerPayouts", fields: [practitionerId], references: [id])
  amount         Float
  paymentDate    DateTime
  periodMonth    Int
  periodYear     Int
  method         String    @default("bank_transfer") // cash | bank_transfer | card | other
  note           String?
  createdById    String
  createdBy      User      @relation("PayoutCreator", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  earnings PractitionerEarning[]

  @@index([clinicId, practitionerId, periodYear, periodMonth])
}

// ── Stok / Malzeme Takibi ────────────────────────────────────────────────────

model InventoryItem {
  id           String   @id @default(uuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  name         String
  // implant | prosthetic | consumable | medication | equipment | other
  category     String   @default("consumable")
  unit         String   @default("piece") // piece | box | ml | gram | vial | set
  currentStock Float    @default(0)
  minimumStock Float    @default(0)   // triggers low-stock alert
  unitCost     Float?
  supplier     String?
  barcode      String?
  notes        String?
  isActive     Boolean  @default(true)
  organizationId String                // Phase 1b: NOT NULL after backfill
  organization   Organization          @relation(fields: [organizationId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions InventoryTransaction[]

  @@index([clinicId, category, isActive])
}

model InventoryTransaction {
  id              String        @id @default(uuid())
  clinicId        String
  clinic          Clinic        @relation(fields: [clinicId], references: [id])
  itemId          String
  item            InventoryItem @relation(fields: [itemId], references: [id])
  // in | out | adjustment
  type            String
  quantity        Float
  unitCost        Float?
  // purchase | usage | treatment_use | adjustment | wastage | return
  reason          String?
  treatmentCaseId String?
  treatmentCase   TreatmentCase? @relation(fields: [treatmentCaseId], references: [id])
  performedById   String
  performedBy     User          @relation("InventoryPerformedBy", fields: [performedById], references: [id])
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([clinicId, itemId, createdAt])
}

// ── Tedavi Planı Görselleştirme ───────────────────────────────────────────────

model TreatmentPlanProcedure {
  id              String           @id @default(uuid())
  clinicId        String
  clinic          Clinic           @relation(fields: [clinicId], references: [id])
  treatmentCaseId String
  treatmentCase   TreatmentCase    @relation(fields: [treatmentCaseId], references: [id])
  patientId       String
  patient         Patient          @relation(fields: [patientId], references: [id])
  toothFdi        Int?             // FDI notation; null = procedure not tooth-specific
  procedureName   String
  serviceId       String?
  service         AppointmentType? @relation(fields: [serviceId], references: [id])
  // planned | in_progress | completed | cancelled
  status          String           @default("planned")
  notes           String?
  estimatedCost   Float?
  scheduledDate   DateTime?
  completedAt     DateTime?
  createdById     String
  createdBy       User             @relation("ProcedureCreator", fields: [createdById], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([clinicId, treatmentCaseId])
  @@index([clinicId, patientId, toothFdi])
}

// ── Kalıcı Bildirimler ────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id])
  // upcoming_appointment | overdue_task | appointment_request | low_stock
  type       String
  title      String
  subtitle   String?
  link       String
  isRead     Boolean  @default(false)
  // deterministic key to prevent duplicate inserts (e.g. "appt-{id}", "lowstock-{itemId}")
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([clinicId, externalId])
  @@index([clinicId, isRead])
}

// ── Multi-Tenant Platform Models ─────────────────────────────────────────────

model Plan {
  id           String   @id @default(uuid())
  name         String   @unique // starter | professional | enterprise
  displayName  String
  maxUsers     Int
  maxPatients  Int
  features     Json     // { "whatsapp": true, "reports": true, "compensation": false }
  monthlyPrice Decimal  @default(0) @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  clinics       Clinic[]
  organizations Organization[]
}

model PlatformAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ClinicInvitation {
  id             String    @id @default(uuid())
  clinicId       String
  clinic         Clinic    @relation(fields: [clinicId], references: [id])
  email          String
  role           String
  token          String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  organizationId String?               // Nullable: set when invitation is org-scoped
  organization   Organization?         @relation(fields: [organizationId], references: [id])
  createdAt      DateTime  @default(now())

  @@index([clinicId, email])
  @@index([token])
}

// ── Multi-Branch Organization Models ─────────────────────────────────────────────────

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  status      String    @default("trial") // trial | active | suspended | cancelled
  planId      String?
  plan        Plan?     @relation(fields: [planId], references: [id])
  trialEndsAt DateTime?
  ownerId     String?   // ID of the founding user (informational)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clinics               Clinic[]
  users                 User[]
  patients              Patient[]
  invitations           ClinicInvitation[]
  inventoryItems        InventoryItem[]
  clinicWorkingHours    ClinicWorkingHours[]
  whatsappConnections   WhatsAppConnection[]
  clinicWhatsAppConnections ClinicWhatsAppConnection[]
  sentMessages          SentMessage[]
  whatsappInboxEntries  WhatsAppInboxEntry[]
  instagramConnections  InstagramConnection[]
  clinicInstagramConnections ClinicInstagramConnection[]
  instagramInboxEntries InstagramInboxEntry[]
}

model UserClinic {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  role      String   // OWNER | ORG_ADMIN | CLINIC_MANAGER | DENTIST | RECEPTIONIST | BILLING | ASSISTANT
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clinicId])
  @@index([clinicId, isActive])
  @@index([userId, isActive])
}

model PatientClinic {
  id           String   @id @default(uuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  firstVisitAt DateTime?
  lastVisitAt  DateTime?
  createdAt    DateTime @default(now())

  @@unique([patientId, clinicId])
  @@index([clinicId])
  @@index([patientId])
}

// ── Şube Çalışma Saatleri ─────────────────────────────────────────────────────

model ClinicWorkingHours {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id])
  dayOfWeek      Int          // 0 Sunday, 1 Monday, ... 6 Saturday
  isClosed       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([clinicId, dayOfWeek])
  @@index([clinicId])
}

// ── Provider-Agnostic WhatsApp Infrastructure ─────────────────────────────────

/// Organization-level WhatsApp connection. One connection can be shared by multiple branches.
model WhatsAppConnection {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  // evolution_api | meta_cloud_api
  provider       String   @default("evolution_api")
  // disconnected | connecting | connected | error
  status         String   @default("disconnected")
  phoneNumber    String?
  displayName    String?

  // Evolution API fields
  evolutionApiUrl          String?
  evolutionInstanceName    String? @unique
  // TODO: encrypt before storing (no encryption utility in this project yet)
  evolutionApiKeyEncrypted String?

  // Meta Cloud API foundation fields
  metaBusinessId           String?
  metaWabaId               String?
  metaPhoneNumberId        String? @unique
  metaAppId                String?
  // TODO: encrypt before storing
  metaAccessTokenEncrypted String?
  metaWebhookVerifyToken   String?
  metaWebhookSecret        String?
  // Token lifecycle tracking — Meta tokens expire ~60 days unless refreshed
  // valid | expiring | expired | unknown
  metaTokenStatus          String?  @default("unknown")
  metaTokenExpiresAt       DateTime?
  metaTokenLastCheckedAt   DateTime?

  // Shared webhook secret for this connection
  webhookSecret    String?
  lastConnectedAt  DateTime?
  lastError        String?
  isActive         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinics        ClinicWhatsAppConnection[]
  sentMessages   SentMessage[]
  inboxEntries   WhatsAppInboxEntry[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([provider])
}

/// Maps one WhatsAppConnection to one Clinic. Supports shared (one connection → many clinics)
/// and dedicated (one connection → one clinic) topology.
model ClinicWhatsAppConnection {
  id                   String   @id @default(uuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id])
  clinicId             String
  clinic               Clinic   @relation(fields: [clinicId], references: [id])
  whatsappConnectionId String
  whatsappConnection   WhatsAppConnection @relation(fields: [whatsappConnectionId], references: [id])
  isDefault            Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([clinicId, whatsappConnectionId])
  @@index([organizationId])
  @@index([clinicId])
  @@index([whatsappConnectionId])
}

/// Incoming WhatsApp messages that could not be automatically assigned to a clinic.
/// Priority A-C resolution routes to existing flow; Priority D creates one of these.
/// After staff resolution: clinicId is set, needsClinicResolution=false, status=resolved.
model WhatsAppInboxEntry {
  id                    String              @id @default(uuid())
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id])
  whatsappConnectionId  String?
  whatsappConnection    WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id])
  clinicId              String?             // null = unresolved
  clinic                Clinic?             @relation("InboxEntryClinic", fields: [clinicId], references: [id])
  patientId             String?             // null = no matched patient yet
  patient               Patient?            @relation("InboxEntryPatient", fields: [patientId], references: [id])
  resolvedByUserId      String?
  resolvedBy            User?               @relation("InboxEntryResolver", fields: [resolvedByUserId], references: [id])
  phone                 String
  displayName           String?
  lastMessageText       String?
  messageCount          Int                 @default(1)
  externalMessageId     String?
  rawPayload            Json?
  needsClinicResolution Boolean             @default(false)
  // open | resolved
  status                String              @default("open")
  resolvedAt            DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([organizationId, needsClinicResolution])
  @@index([organizationId, status])
  @@index([organizationId, clinicId])
  @@index([whatsappConnectionId, phone])
}

// ── Sprint 13: Operational Monitoring ────────────────────────────────────────

/// Immutable audit trail of important admin/system actions.
/// Separate from ActivityLog (clinic-scoped, FK-heavy) — AuditLog is org-scoped
/// and designed for compliance, security reviews and operational investigations.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  clinicId       String?
  actorUserId    String?
  actorRole      String?
  action         String   // user_login | branch_created | payment_created | ...
  entityType     String   // user | branch | appointment | payment | whatsapp_connection | ...
  entityId       String?
  description    String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([clinicId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

/// System-level operational events: integration failures, webhook errors, etc.
/// Separate from AuditLog — these are monitorable / resolvable events.
model OperationalEvent {
  id             String    @id @default(uuid())
  organizationId String
  clinicId       String?
  // info | warning | error | critical
  severity       String    @default("info")
  // whatsapp | appointment | finance | auth | system
  source         String
  message        String
  metadata       Json?
  resolvedAt     DateTime?
  resolvedById   String?
  createdAt      DateTime  @default(now())

  @@index([organizationId, severity])
  @@index([organizationId, source])
  @@index([organizationId, resolvedAt])
  @@index([createdAt])
}

// ── Sprint 23: Instagram DM Integration ──────────────────────────────────────

/// Organization-level Instagram DM connection. One connection can be shared by multiple branches.
/// Architecture: dedicated InstagramConnection model (Option B) to avoid disrupting WhatsApp.
model InstagramConnection {
  id                      String   @id @default(uuid())
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id])
  name                    String
  /// disconnected | connecting | connected | error
  status                  String   @default("disconnected")
  instagramAccountId      String? @unique
  instagramUsername       String?
  facebookPageId          String?
  /// AES-256-GCM encrypted Meta access token
  accessTokenEncrypted    String?
  /// Page-scoped access token (if different from user token)
  pageAccessTokenEncrypted String?
  webhookVerifyToken      String?
  webhookSecret           String?
  metaAppId               String?
  metaBusinessId          String?
  /// valid | expiring | expired | unknown
  tokenStatus             String?  @default("unknown")
  tokenExpiresAt          DateTime?
  lastConnectedAt         DateTime?
  lastError               String?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  clinics      ClinicInstagramConnection[]
  inboxEntries InstagramInboxEntry[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

/// Maps one InstagramConnection to one Clinic (shared or dedicated topology).
model ClinicInstagramConnection {
  id                    String   @id @default(uuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id])
  clinicId              String
  clinic                Clinic   @relation(fields: [clinicId], references: [id])
  instagramConnectionId String
  instagramConnection   InstagramConnection @relation(fields: [instagramConnectionId], references: [id])
  isDefault             Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([clinicId, instagramConnectionId])
  @@index([organizationId])
  @@index([clinicId])
  @@index([instagramConnectionId])
}

/// Incoming Instagram DMs stored for staff review, patient linking, and appointment conversion.
/// Priority C (single-clinic) auto-assigns; Priority D creates an unresolved entry.
model InstagramInboxEntry {
  id                      String              @id @default(uuid())
  organizationId          String
  organization            Organization        @relation(fields: [organizationId], references: [id])
  instagramConnectionId   String?
  instagramConnection     InstagramConnection? @relation(fields: [instagramConnectionId], references: [id])
  clinicId                String?
  clinic                  Clinic?             @relation("InstagramInboxEntryClinic", fields: [clinicId], references: [id])
  patientId               String?
  patient                 Patient?            @relation("InstagramInboxEntryPatient", fields: [patientId], references: [id])
  resolvedByUserId        String?
  resolvedBy              User?               @relation("InstagramInboxEntryResolver", fields: [resolvedByUserId], references: [id])
  /// Instagram sender IGSID (unique Instagram-scoped user ID)
  externalSenderId        String
  /// Instagram conversation/thread ID if provided
  externalConversationId  String?
  senderUsername          String?
  lastMessageText         String?
  messageCount            Int                 @default(1)
  externalMessageId       String?
  rawPayload              Json?
  needsClinicResolution   Boolean             @default(false)
  /// open | resolved | ignored
  status                  String              @default("open")
  resolvedAt              DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([organizationId, needsClinicResolution])
  @@index([organizationId, status])
  @@index([organizationId, clinicId])
  @@index([instagramConnectionId, externalSenderId])
}
