DATABASE_URL="postgresql://crm_user:change-me@localhost:5432/dis_klinik_crm?schema=public"
JWT_SECRET="change-me-to-at-least-32-random-characters"
# Platform admin panel JWT secret (separate from regular JWT_SECRET)
PLATFORM_JWT_SECRET="change-me-to-a-different-32-random-character-secret"
WHATSAPP_WEBHOOK_SECRET="change-me-to-a-random-webhook-secret"
PORT=5000
CORS_ORIGINS="http://localhost:5173"
JSON_BODY_LIMIT="1mb"
# Session cookies.
# Production web target: frontend https://<domain>, API https://<domain>/api.
# Keep SameSite=Lax and leave SESSION_COOKIE_DOMAIN empty for this same-origin setup.
CSRF_SECRET="change-me-to-a-different-32-random-character-secret"
SESSION_COOKIE_SAMESITE="lax"
SESSION_COOKIE_SECURE=false
# Production:
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_DOMAIN=
# Keep Bearer fallback enabled during cookie migration. Set false after
# production-like cookie auth is verified and all clients have moved to cookies.
AUTH_BEARER_FALLBACK_ENABLED=true
# CLINIC_BEARER_FALLBACK_ENABLED=true
# PLATFORM_BEARER_FALLBACK_ENABLED=true
EVOLUTION_API_BASE_URL="http://localhost:8080"
EVOLUTION_API_KEY="change-me"
EVOLUTION_INSTANCE_NAME="disklinikcrm"

# Panel-first WhatsApp mode.
# Set to "false" in production once all connections have been imported via the panel
# (Organization → WhatsApp → Panel Yönetimine Aktar) and verified.
# Default: false in production. Keep false for tenant-safe webhook routing.
# See migration guide in server/src/utils/legacyWhatsApp.ts.
ENABLE_LEGACY_WHATSAPP_ENV_FALLBACK=false

# AI / Gemini (optional — for WhatsApp bot auto-reply)
GEMINI_API_KEY=""
GOOGLE_AI_MODEL="gemini-2.0-flash"

# Meta Cloud API (Backend)
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v23.0
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_REDIRECT_URI=
META_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
# AES-256-GCM encryption key for WhatsApp connection tokens (64 hex chars)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Stripe SaaS Billing ───────────────────────────────────────────────────────
# Platform charges clinics for CRM subscriptions. NOT for patient payments.
# Obtain from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Obtain from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# URLs Stripe redirects to after checkout / billing portal
STRIPE_SUCCESS_URL=http://localhost:5173/settings/billing?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/settings/billing
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173/settings/billing
