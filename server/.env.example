DATABASE_URL="postgresql://crm_user:change-me@localhost:5432/noramedi_crm?schema=public"
# Postgres bağlantı havuzu (pg Pool). DB_POOL_MAX: süreç başına en fazla
# bağlantı (varsayılan 10; Postgres max_connections sınırını replika sayısıyla
# birlikte düşünün). CONNECT_TIMEOUT: havuzdan bağlantı bekleme üst sınırı.
# DB_POOL_MAX=10
# DB_POOL_CONNECT_TIMEOUT_MS=10000
# DB_POOL_IDLE_TIMEOUT_MS=30000
JWT_SECRET="change-me-to-at-least-32-random-characters"
# Platform admin panel JWT secret (separate from regular JWT_SECRET)
PLATFORM_JWT_SECRET="change-me-to-a-different-32-random-character-secret"
WHATSAPP_WEBHOOK_SECRET="change-me-to-a-random-webhook-secret"
PORT=5000
# Bind address. Set to 127.0.0.1 in production so the port is not reachable
# directly from the network (Nginx proxies through loopback). Default: 0.0.0.0.
# Production: LISTEN_HOST=127.0.0.1
LISTEN_HOST=0.0.0.0
CORS_ORIGINS="http://localhost:5173"
# Development:
# CORS_ORIGINS="http://localhost:5173"
# Production:
CORS_ORIGINS="https://app.noramedi.com,https://noramedi.com"
FRONTEND_URL=https://app.noramedi.com
JSON_BODY_LIMIT="1mb"
# Session cookies.
# Production: frontend https://app.noramedi.com, API https://api.noramedi.com
# Cross-subdomain: set SESSION_COOKIE_DOMAIN=.noramedi.com and SESSION_COOKIE_SAMESITE=none (requires HTTPS).
# Same-origin (API proxied under /api): leave SESSION_COOKIE_DOMAIN empty, SameSite=lax.
CSRF_SECRET="change-me-to-a-different-32-random-character-secret"
# Imaging bridge pairing code HMAC pepper — required (>=32 chars) in production.
# Without it, pairing codes would be reversible sha256(code) hashes only.
IMAGING_BRIDGE_PAIRING_PEPPER="change-me-to-a-different-32-random-character-secret"
# Self-service Windows imaging bridge onboarding UI — keep false until the full
# release gate (installer, PR 1-7) passes. Backend endpoints exist regardless.
BRIDGE_SELF_SERVICE_ENABLED=false
# Windows Bridge web onboarding (PR 5/7) — GET /api/imaging/bridge-onboarding/config.
# Fail-closed: leave false in production until a signed installer is published
# and this whole 7-PR feature is ready for general availability.
IMAGING_BRIDGE_ONBOARDING_ENABLED=false
# Only used when IMAGING_BRIDGE_ONBOARDING_ENABLED=true. Must be HTTPS in
# production (a localhost http:// URL is only accepted outside production).
IMAGING_BRIDGE_INSTALLER_DOWNLOAD_URL=
# x.y.z (matches the installer's ProductVersion, e.g. from installer.md)
IMAGING_BRIDGE_INSTALLER_VERSION=
# 64-char lowercase hex SHA-256 of NoraMediBridgeSetup.exe
IMAGING_BRIDGE_INSTALLER_SHA256=
# Set true only once the installer is Authenticode-signed — never claim an
# unsigned installer is signed (see windows-bridge/docs/installer.md).
IMAGING_BRIDGE_INSTALLER_SIGNED=false
# Windows Bridge auto-update (PR 6/7, GET /api/public/imaging/bridge/update).
# disabled (default) | notify | automatic. Unset/unrecognized -> disabled —
# fail closed. See windows-bridge/docs/update-server.md.
IMAGING_BRIDGE_UPDATE_MODE=disabled
# x.y.z / x.y.z.w — must match the MSI/Bundle ProductVersion of the offered release.
IMAGING_BRIDGE_UPDATE_VERSION=
# HTTPS required in production (localhost http allowed only outside production).
IMAGING_BRIDGE_UPDATE_DOWNLOAD_URL=
# 64-char lowercase hex SHA-256 of NoraMediBridgeSetup.exe for this release.
IMAGING_BRIDGE_UPDATE_SHA256=
# Set true only once the installer is Authenticode-signed by the pinned
# publisher below. In production, an unsigned release is never offered.
IMAGING_BRIDGE_UPDATE_SIGNED=false
# 40-char hex Authenticode certificate thumbprint the bridge pins as the
# only trusted publisher for this release. Required when *_SIGNED=true.
IMAGING_BRIDGE_UPDATE_PUBLISHER_THUMBPRINT=
# Optional: oldest installed source version this release supports upgrading
# from (x.y.z). Leave blank to allow any older version.
IMAGING_BRIDGE_UPDATE_MIN_SOURCE_VERSION=
# Optional short release notes surfaced in the Manager update UI.
IMAGING_BRIDGE_UPDATE_NOTES=
SESSION_COOKIE_SAMESITE="lax"
SESSION_COOKIE_SECURE=false
# Production:
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_DOMAIN=
# Bearer token fallback is OFF by default (the frontend is fully cookie-based
# and Bearer requests bypass CSRF). Enable only temporarily during a migration.
# AUTH_BEARER_FALLBACK_ENABLED=false
# CLINIC_BEARER_FALLBACK_ENABLED=false
# PLATFORM_BEARER_FALLBACK_ENABLED=false
# Hop count (or true/false/subnet list) for Express trust proxy. Default 1 —
# correct when the app sits behind a single Nginx; IP rate limits depend on it.
# TRUST_PROXY=1
EVOLUTION_API_BASE_URL="http://localhost:8080"
EVOLUTION_API_KEY="change-me"
EVOLUTION_INSTANCE_NAME="noramedi"

# Panel-first WhatsApp mode.
# Set to "false" in production once all connections have been imported via the panel
# (Organization → WhatsApp → Panel Yönetimine Aktar) and verified.
# Default: false in production. Keep false for tenant-safe webhook routing.
# See migration guide in server/src/utils/legacyWhatsApp.ts.
ENABLE_LEGACY_WHATSAPP_ENV_FALLBACK=false

# AI / Gemini (optional — for WhatsApp bot auto-reply)
GEMINI_API_KEY=""
GOOGLE_AI_MODEL="gemini-2.0-flash"

# Meta Cloud API (Backend)
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v23.0
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_REDIRECT_URI=
META_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
# AES-256-GCM encryption key for WhatsApp connection tokens (64 hex chars)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Set MAIL_ENABLED=true and provide SMTP credentials to enable email sending.
# Works with any SMTP provider: Brevo, Mailgun, Postmark, Amazon SES, own server.
# When MAIL_ENABLED=false (default), forgot-password still returns generic success
# but no email is sent — safe for development.
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NoraMedi <no-reply@noramedi.com>"
SMTP_REPLY_TO=
# Base URL for password reset links sent in emails (no trailing slash)
APP_BASE_URL=https://app.noramedi.com
