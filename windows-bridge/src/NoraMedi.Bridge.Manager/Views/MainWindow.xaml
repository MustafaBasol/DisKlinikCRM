<Window x:Class="NoraMedi.Bridge.Manager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:NoraMedi.Bridge.Manager.Converters"
        xmlns:res="clr-namespace:NoraMedi.Bridge.Manager.Resources"
        Title="{x:Static res:Strings.AppTitle}"
        Width="720" Height="520"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:EnumEqualsConverter x:Key="EnumEquals" />
        <conv:NullableBoolToTextConverter x:Key="NullableBoolToText" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status pill, always visible -->
        <Border Grid.Row="0" Style="{StaticResource StatusPill}" HorizontalAlignment="Left">
            <TextBlock Text="{Binding Status.StatusLabel}" FontWeight="SemiBold" />
        </Border>

        <!-- Unmissable elevation banner: shown whenever a privileged op comes back unauthorized -->
        <Border Grid.Row="1" Background="#FFF4CE" BorderBrush="#D9A400" BorderThickness="1" Padding="10" Margin="0,8,0,8"
                Visibility="{Binding IsElevationRequired, Converter={StaticResource EnumEquals}, ConverterParameter=True, FallbackValue=Collapsed}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{x:Static res:Strings.Msg_ElevationRequired}" VerticalAlignment="Center" Width="*" TextWrapping="Wrap" />
                <Button Content="{x:Static res:Strings.Button_RestartElevated}" Command="{Binding RestartElevatedCommand}" Margin="12,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Feature-disabled full gate: one clear message, no button-mashing loop -->
        <Grid Grid.Row="2" Visibility="{Binding Status.State, Converter={StaticResource EnumEquals}, ConverterParameter=FeatureDisabled}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                <TextBlock Text="{x:Static res:Strings.Msg_FeatureDisabled}" TextAlignment="Center" TextWrapping="Wrap" />
                <Button Content="{x:Static res:Strings.Button_Refresh}" Command="{Binding Status.RefreshCommand}" HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Grid>

        <!-- Service-unavailable full gate -->
        <Grid Grid.Row="2" Visibility="{Binding Status.State, Converter={StaticResource EnumEquals}, ConverterParameter=ServiceUnavailable}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                <TextBlock Text="{x:Static res:Strings.Msg_ServiceUnavailable}" TextAlignment="Center" TextWrapping="Wrap" />
                <Button Content="{x:Static res:Strings.Button_Refresh}" Command="{Binding Status.RefreshCommand}" HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Grid>

        <!-- Main tabbed workspace: only meaningful once the feature is enabled and the service is reachable -->
        <TabControl Grid.Row="2" x:Name="WorkspaceTabs">
            <TabControl.Style>
                <Style TargetType="TabControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status.State}" Value="FeatureDisabled">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status.State}" Value="ServiceUnavailable">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>

            <TabItem Header="{x:Static res:Strings.Tab_Status}">
                <StackPanel Margin="12">
                    <TextBlock Text="{x:Static res:Strings.Tab_Status}" Style="{StaticResource HeadingText}" />
                    <TextBlock>
                        <Run Text="Agent version: " /><Run Text="{Binding Status.AgentVersion, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Paired: " /><Run Text="{Binding Status.Paired, Mode=OneWay}" />
                    </TextBlock>
                    <Button Content="{x:Static res:Strings.Button_Refresh}" Command="{Binding Status.RefreshCommand}"
                            IsEnabled="{Binding Status.IsBusy, Converter={StaticResource EnumEquals}, ConverterParameter=False}" />
                    <Button Content="{x:Static res:Strings.Button_TestConnection}" Command="{Binding Status.TestConnectionCommand}" />
                    <TextBlock Text="{Binding Status.TestConnectionMessage}" />
                    <ProgressBar IsIndeterminate="True" Height="4" Visibility="{Binding Status.IsBusy, Converter={StaticResource EnumEquals}, ConverterParameter=True}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{x:Static res:Strings.Tab_Pairing}">
                <StackPanel Margin="12" MaxWidth="360" HorizontalAlignment="Left">
                    <TextBlock Text="{x:Static res:Strings.Tab_Pairing}" Style="{StaticResource HeadingText}" />
                    <TextBlock Text="{x:Static res:Strings.Label_PairingCode}" />
                    <TextBox x:Name="PairingCodeBox" TextChanged="PairingCodeBox_TextChanged" MaxLength="9"
                             Text="{Binding Pairing.DisplayText, Mode=OneWay}" />
                    <TextBlock Text="{x:Static res:Strings.Label_ComputerName}" />
                    <TextBox Text="{Binding Pairing.ComputerDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="{x:Static res:Strings.Button_Submit}" Command="{Binding Pairing.SubmitCommand}" IsDefault="True" />
                    <ProgressBar IsIndeterminate="True" Height="4" Visibility="{Binding Pairing.IsBusy, Converter={StaticResource EnumEquals}, ConverterParameter=True}" />
                    <TextBlock Text="{Binding Pairing.ResultMessage}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{x:Static res:Strings.Tab_Bindings}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{x:Static res:Strings.Tab_Bindings}" Style="{StaticResource HeadingText}" />

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Bindings.Bindings}" AutoGenerateColumns="True"
                              IsReadOnly="True" MinHeight="120" />

                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding Bindings.FolderPath, UpdateSourceTrigger=PropertyChanged}" Width="*" MinWidth="220" />
                            <Button Content="{x:Static res:Strings.Button_Browse}" Command="{Binding Bindings.BrowseFolderCommand}" />
                        </StackPanel>
                        <TextBlock Text="{x:Static res:Strings.Label_DeviceId}" />
                        <TextBox Text="{Binding Bindings.DeviceId, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{x:Static res:Strings.Label_Modality}" />
                        <TextBox Text="{Binding Bindings.Modality, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{x:Static res:Strings.Button_Validate}" Command="{Binding Bindings.ValidateFolderCommandInstance}" />
                            <Button Content="{x:Static res:Strings.Button_Save}" Command="{Binding Bindings.SaveCommand}" />
                            <Button Content="{x:Static res:Strings.Button_Remove}" Command="{Binding Bindings.RemoveCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding Bindings.FolderStatusLabel}" />
                        <TextBlock Text="{Binding Bindings.StatusMessage}" />
                        <ProgressBar IsIndeterminate="True" Height="4" Visibility="{Binding Bindings.IsBusy, Converter={StaticResource EnumEquals}, ConverterParameter=True}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static res:Strings.Tab_Queue}">
                <StackPanel Margin="12" MaxWidth="420" HorizontalAlignment="Left">
                    <TextBlock Text="{x:Static res:Strings.Tab_Queue}" Style="{StaticResource HeadingText}" />
                    <UniformGrid Columns="4">
                        <StackPanel>
                            <TextBlock Text="Pending" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Queue.Pending}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Processing" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Queue.Processing}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Failed" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Queue.Failed}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Completed" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Queue.Completed}" />
                        </StackPanel>
                    </UniformGrid>
                    <Button Content="{x:Static res:Strings.Button_Refresh}" Command="{Binding Queue.RefreshCommand}" />
                    <TextBlock Text="{x:Static res:Strings.Label_IngestKey}" />
                    <TextBox Text="{Binding Queue.RetryIngestKey, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="{x:Static res:Strings.Button_Retry}" Command="{Binding Queue.RetryCommand}" />
                    <TextBlock Text="{Binding Queue.RetryMessage}" />
                    <TextBlock Text="{Binding Queue.StatusMessage}" />
                    <ProgressBar IsIndeterminate="True" Height="4" Visibility="{Binding Queue.IsBusy, Converter={StaticResource EnumEquals}, ConverterParameter=True}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{x:Static res:Strings.Tab_Diagnostics}">
                <StackPanel Margin="12" MaxWidth="420" HorizontalAlignment="Left">
                    <TextBlock Text="{x:Static res:Strings.Tab_Diagnostics}" Style="{StaticResource HeadingText}" />
                    <Button Content="{x:Static res:Strings.Button_Export}" Command="{Binding Diagnostics.ExportCommand}" />
                    <TextBlock Text="{Binding Diagnostics.StatusMessage}" />
                    <ProgressBar IsIndeterminate="True" Height="4" Visibility="{Binding Diagnostics.IsBusy, Converter={StaticResource EnumEquals}, ConverterParameter=True}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{x:Static res:Strings.Tab_Updates}">
                <StackPanel Margin="12" MaxWidth="420" HorizontalAlignment="Left">
                    <TextBlock Text="{x:Static res:Strings.Tab_Updates}" Style="{StaticResource HeadingText}" />
                    <Button Content="{x:Static res:Strings.Button_CheckForUpdates}" Command="{Binding Update.CheckForUpdatesCommand}" />
                    <TextBlock Text="{Binding Update.Message}" />
                    <ProgressBar IsIndeterminate="True" Height="4" Visibility="{Binding Update.IsBusy, Converter={StaticResource EnumEquals}, ConverterParameter=True}" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
